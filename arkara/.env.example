# OpenRouter AI Text Generation
OPENROUTER_API_KEY=sk-or-...

# Wavespeed / Nano Banana 2 Image Generation
WAVESPEED_API_KEY=...

# S3 / Tigris Storage (Railway auto-injects AWS_* vars, map them here)
S3_ENDPOINT=https://fly.storage.tigris.dev
S3_REGION=auto
S3_BUCKET_NAME=arkara-media
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_PUBLIC_URL=https://arkara-media.fly.storage.tigris.dev

# Cloudflare R2 media migration (server/local only; keep secrets out of git)
# The migration script also reads SUPABASE_SERVICE_ROLE_KEY from ../nextjsCMS/.env.local.
R2_ACCOUNT_ID=...
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=arkara-media
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_PUBLIC_URL=https://media.arkaraweb.com
SUPABASE_MEDIA_BUCKET=media
SUPABASE_MEDIA_PREFIX=uploads/

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Site Configuration
PUBLIC_SITE_URL=https://arkara.id
PUBLIC_ASSISTANT_API_URL=https://assistant-api.up.railway.app
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
