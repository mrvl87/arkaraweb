---
import { getRelatedPosts, getRelatedPanduan } from '../../lib/content';

interface Props {
  currentSlug: string;
  category?: string;
  contentType: 'blog' | 'panduan';
}

const { currentSlug, category, contentType } = Astro.props;

let relatedItems: Array<{title: string, slug: string, category?: string}> = [];

if (contentType === 'blog') {
  const posts = await getRelatedPosts(currentSlug, category, 3);
  relatedItems = posts.map(p => ({ title: p.title, slug: `/blog/${p.slug}`, category: p.category }));
} else {
  const guides = await getRelatedPanduan(currentSlug, category, 3);
  relatedItems = guides.map(g => ({ title: g.title, slug: `/panduan/${g.slug}`, category: g.category }));
}
---

{relatedItems.length > 0 && (
  <div style="margin-top: 4rem; padding-top: 2rem; border-top: 3px solid var(--ink);">
    <h3 style="
      font-family: 'Share Tech Mono', monospace;
      font-size: 1rem;
      letter-spacing: 0.15em;
      color: var(--green-dark);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    ">
      <span style="display:inline-block;width:24px;height:3px;background:var(--green-terminal);"></span>
      {contentType === 'blog' ? 'ARTIKEL TERKAIT' : 'PANDUAN TERKAIT'}
    </h3>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem;">
      {relatedItems.map(item => (
        <a href={item.slug} class="card-ink" style="
          padding: 1.25rem; 
          text-decoration: none; 
          display: flex; 
          flex-direction: column; 
          gap: 0.75rem;
          background: var(--paper-dark);
        ">
          <div style="
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.65rem;
            color: var(--green-dark);
            letter-spacing: 0.15em;
            text-transform: uppercase;
          ">
            {item.category || 'MANDIRI'}
          </div>
          <h4 style="
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--ink);
            line-height: 1.15;
            margin: 0;
            text-transform: uppercase;
          ">
            {item.title}
          </h4>
          <div style="margin-top: auto; padding-top: 0.75rem; font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; color: var(--green-terminal); font-weight: bold;">
            BACA SEKARANG ➔
          </div>
        </a>
      ))}
    </div>
  </div>
)}
