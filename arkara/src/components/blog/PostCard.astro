---
/**
 * PostCard.astro — Retro Survival Manual 2.0
 * Props: unchanged (backward compatible)
 * Changes:
 *   - Removed: rounded-2xl, shadow-sm, hover:shadow-xl, gradient-br
 *   - Added: ink border, box-shadow offset, flat image filter
 *   - Category badge: mono font, ink style (not backdrop-blur)
 *   - "Lanjutkan →" replaced with mono-style label
 */
import OptimizedImage from '../ui/OptimizedImage.astro';
import { calculateReadingTime } from '../../lib/markdown';

interface Props {
  title: string;
  excerpt: string;
  category: string;
  date: string;
  slug: string;
  content: string;
  image?: any;
  sizes?: string;
}

const { title, excerpt, category, date, slug, content, image, sizes } = Astro.props;
const readingTime = calculateReadingTime(content || '');

const formattedDate = new Date(date).toLocaleDateString('id-ID', {
  day: 'numeric', month: 'short', year: 'numeric'
});
---

<article style="
  background: var(--paper);
  border: 3px solid var(--ink);
  box-shadow: 5px 5px 0 var(--ink);
  display: flex;
  flex-direction: column;
  height: 100%;
  transition: transform 0.15s, box-shadow 0.15s;
  position: relative;
"
onmouseover="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='7px 7px 0 var(--ink)'"
onmouseout="this.style.transform='';this.style.boxShadow='5px 5px 0 var(--ink)'"
>
  {image && (
    <div style="overflow: hidden; border-bottom: 3px solid var(--ink); position: relative;">
      <OptimizedImage
        image={image}
        alt={title}
        class="w-full object-cover"
        style="filter: saturate(0.65) contrast(1.08); display: block; aspect-ratio: 16/9;"
        aspectRatio="aspect-video"
        sizes={sizes}
        mobileMaxSrcSetWidth={800}
        maxSrcSetWidth={800}
      />
      <!-- Category stamp -->
      <div style="
        position: absolute; top: 0.75rem; left: 0.75rem;
        background: var(--ink);
        border: 1px solid var(--green-terminal);
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.18em;
        color: var(--green-terminal);
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
      ">{category}</div>
    </div>
  )}

  <div style="padding: 1.5rem; display: flex; flex-direction: column; flex: 1; gap: 0.6rem;">

    <!-- Meta row -->
    <div style="
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.12em;
      color: var(--warm-grey);
      text-transform: uppercase;
      display: flex; align-items: center; gap: 0.75rem;
    ">
      <time datetime={date}>{formattedDate}</time>
      <span style="color: var(--cream-dark);">·</span>
      <span>{readingTime} MIN READ</span>
      {!image && (
        <>
          <span style="color: var(--cream-dark);">·</span>
          <span style="color: var(--green-terminal);">{category}</span>
        </>
      )}
    </div>

    <!-- Title -->
    <a href={`/blog/${slug}`} style="text-decoration: none;">
      <h3 style="
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 1.4rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--ink);
        line-height: 1.1;
        transition: color 0.15s;
        margin: 0;
      "
      onmouseover="this.style.color='var(--green-dark)'"
      onmouseout="this.style.color='var(--ink)'"
      >{title}</h3>
    </a>

    <!-- Excerpt -->
    <p style="
      font-size: 0.82rem;
      color: var(--warm-grey-dark);
      line-height: 1.65;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin: 0;
    ">{excerpt}</p>

    <!-- Footer -->
    <div style="
      padding-top: 0.75rem;
      border-top: 1px dashed var(--cream-dark);
      display: flex;
      justify-content: flex-end;
    ">
      <a href={`/blog/${slug}`} style="
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.15em;
        color: var(--green-terminal);
        text-transform: uppercase;
        text-decoration: none;
        border: 1px solid var(--green-terminal);
        padding: 0.3rem 0.65rem;
        transition: background 0.15s;
      "
      onmouseover="this.style.background='var(--green-dark)'"
      onmouseout="this.style.background=''"
      >BACA →</a>
    </div>
  </div>
</article>
