---
/**
 * FeaturedPost.astro — Retro Survival Manual 2.0
 * Props: unchanged — post: any, categoryLabel: string
 * Changes:
 *   - Removed: rounded-3xl, hover:shadow-xl, gradient-br from white
 *   - Added: ink border + offset shadow, flat image filter, mono labels
 *   - "Terbaru" badge: terminal style
 *   - CTA: btn-primary retro style
 */
import OptimizedImage from '../ui/OptimizedImage.astro';
import ReadingMeta from './ReadingMeta.astro';
import { calculateReadingTime } from '../../lib/markdown';

interface Props {
  post: any;
  categoryLabel: string;
}

const { post, categoryLabel } = Astro.props;
const readingTime = calculateReadingTime(post.content || '');
---

<article style="
  background: var(--paper);
  border: 3px solid var(--ink);
  box-shadow: 7px 7px 0 var(--ink);
  margin-bottom: 3rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
  transition: transform 0.15s, box-shadow 0.15s;
"
onmouseover="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='9px 9px 0 var(--ink)'"
onmouseout="this.style.transform='';this.style.boxShadow='7px 7px 0 var(--ink)'"
class="featured-grid"
>
  <!-- Image side -->
  <div style="position: relative; overflow: hidden; border-right: 3px solid var(--ink);" class="featured-img-side">
    <OptimizedImage
      image={post.banner_image || post.cover_image}
      alt={post.title}
      class="w-full h-full object-cover"
      style="filter: saturate(0.65) contrast(1.1); display: block; min-height: 320px;"
      aspectRatio="aspect-video"
      mobileMaxSrcSetWidth={800}
      mobileSizes="100vw"
    />
    <!-- TERBARU stamp -->
    <div style="
      position: absolute; top: 1rem; left: 1rem;
      background: var(--ink);
      border: 2px solid var(--yellow-manual);
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      color: var(--yellow-manual);
      text-transform: uppercase;
      padding: 0.3rem 0.7rem;
      transform: rotate(-1deg);
    ">★ TERBARU</div>
  </div>

  <!-- Content side -->
  <div style="padding: 2.5rem; display: flex; flex-direction: column; justify-content: center; background: var(--paper);" class="featured-body-padding">

    <!-- Meta -->
    <div style="
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.18em;
      color: var(--warm-grey);
      text-transform: uppercase;
      margin-bottom: 1rem;
      display: flex; align-items: center; gap: 0.75rem;
    ">
      <span style="color: var(--green-terminal);">{categoryLabel}</span>
      <span>·</span>
      <time>{post.published_at ? new Date(post.published_at).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) : ''}</time>
      <span>·</span>
      <span>{readingTime} MIN</span>
    </div>

    <!-- Title -->
    <a href={`/blog/${post.slug}`} style="text-decoration: none; margin-bottom: 1rem; display: block;">
      <h2 style="
        font-family: 'Barlow Condensed', sans-serif;
        font-size: clamp(1.5rem, 3vw, 2.4rem);
        font-weight: 800;
        text-transform: uppercase;
        color: var(--ink);
        line-height: 1.0;
        transition: color 0.15s;
        margin: 0;
      "
      onmouseover="this.style.color='var(--green-dark)'"
      onmouseout="this.style.color='var(--ink)'"
      >{post.title}</h2>
    </a>

    <!-- Description -->
    <p style="
      font-size: 0.85rem;
      color: var(--warm-grey-dark);
      line-height: 1.65;
      margin-bottom: 1.5rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    ">{post.description}</p>

    <!-- CTA -->
    <a href={`/blog/${post.slug}`} style="
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.75rem 1.5rem;
      background: var(--ink);
      color: var(--green-terminal);
      border: 2px solid var(--green-terminal);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      align-self: flex-start;
      transition: all 0.15s;
    "
    onmouseover="this.style.background='var(--green-dark)';this.style.transform='translate(-2px,-2px)';this.style.boxShadow='4px 4px 0 var(--green-terminal)'"
    onmouseout="this.style.background='var(--ink)';this.style.transform='';this.style.boxShadow=''"
    >▶ BACA SELENGKAPNYA</a>
  </div>
</article>

<style>
  @media (max-width: 768px) {
    .featured-grid { grid-template-columns: 1fr !important; }
    .featured-img-side { border-right: none !important; border-bottom: 3px solid var(--ink); }
    .featured-body-padding { padding: 1.5rem !important; }
  }
</style>
