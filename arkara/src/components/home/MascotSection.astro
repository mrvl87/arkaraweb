---
import { OptimizedImage } from '../components/ui/OptimizedImage';

interface Props {
  mascotImage?: any;
  speechText?: string;
  tagline?: string;
}

const { 
  mascotImage, 
  speechText = "Siap siaga adalah kunci bertahan hidup!", 
  tagline = "Arkara Guide" 
} = Astro.props;

// Normalisasi URL mascot
const mascotUrl = mascotImage?.url || "/placeholder-mascot.png";
---

<div class="flex flex-col items-center justify-center p-8 bg-[#fdfaf1] border-l border-zinc-200 h-full relative overflow-hidden">
  {/* Speech Bubble */}
  <div class="relative mb-8 max-w-[280px] animate-bounce-subtle">
    <div class="bg-white border-4 border-zinc-900 p-4 rounded-3xl shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] relative z-10">
      <p class="text-zinc-900 font-bold text-center leading-tight">
        "{speechText}"
      </p>
    </div>
    {/* Bubble Tail */}
    <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-white border-r-4 border-b-4 border-zinc-900 rotate-45 z-0 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"></div>
  </div>

  {/* Mascot Image Container */}
  <div class="relative group mt-4">
    <div class="absolute -inset-4 bg-amber-400/20 rounded-full blur-2xl group-hover:bg-amber-400/30 transition-all duration-500"></div>
    <div class="relative w-64 h-64 flex items-center justify-center">
       {mascotImage ? (
         <OptimizedImage 
           src={mascotUrl} 
           alt="Arkara Mascot" 
           width={400} 
           height={400}
           className="w-full h-full object-contain filter drop-shadow-[0_10px_10px_rgba(0,0,0,0.1)] group-hover:scale-105 transition-transform duration-500"
         />
       ) : (
         <div class="w-full h-full bg-zinc-100 rounded-3xl border-4 border-dashed border-zinc-300 flex items-center justify-center text-zinc-400 font-bold">
           Mascot Image
         </div>
       )}
    </div>
  </div>

  {/* Tagline */}
  <div class="mt-8 text-center">
    <h3 class="text-2xl font-black text-zinc-900 uppercase tracking-tighter mix-blend-multiply">
      {tagline}
    </h3>
    <div class="h-1.5 w-12 bg-amber-500 mx-auto mt-2 rounded-full shadow-[2px_2px_0px_rgba(0,0,0,1)]"></div>
  </div>
</div>

<style>
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }
  .animate-bounce-subtle {
    animation: bounce-subtle 4s ease-in-out infinite;
  }
</style>
