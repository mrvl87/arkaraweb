---
import OptimizedImage from '../ui/OptimizedImage.astro';
import ReadingMeta from '../blog/ReadingMeta.astro';
import { calculateReadingTime } from '../../lib/markdown';

interface Props {
  posts: any[];
}

const { posts = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  air: 'Air',
  energi: 'Energi',
  pangan: 'Pangan',
  medis: 'Medis',
  keamanan: 'Keamanan',
  komunitas: 'Komunitas',
};
---

<section class="relative w-full overflow-hidden bg-forest group/carousel h-[550px] md:h-[650px]">
  <div id="carousel-container" class="flex transition-transform duration-700 ease-in-out h-full w-full">
    {posts.map((post, index) => (
      <div class="min-w-full h-full relative flex items-center justify-center isolate overflow-hidden">
        <!-- Background Overlay / Image -->
        <div class="absolute inset-0 z-[-1]">
          {post.banner_image || post.cover_image ? (
            <>
              <OptimizedImage 
                image={post.banner_image || post.cover_image} 
                alt={post.title}
                class="w-full h-full object-cover transform scale-105"
              />
              <!-- Stronger Readability Overlays -->
              <div class="absolute inset-0 bg-black/40 shadow-inner"></div> <!-- Base darkening -->
              <div class="absolute inset-0 bg-gradient-to-t from-forest via-forest/80 to-black/20"></div> <!-- Vertical gradient -->
              <div class="absolute inset-0 bg-forest/30 backdrop-blur-[1px]"></div> <!-- Tint -->
            </>
          ) : (
             <div class="w-full h-full bg-gradient-to-br from-forest via-forest/90 to-amber-900/40"></div>
          )}
          <!-- Texture -->
          <div class="absolute inset-0 opacity-10 pointer-events-none bg-[radial-gradient(#E6D8B5_1.5px,transparent_1.5px)] [background-size:24px_24px]"></div>
        </div>

        <!-- Content -->
        <div class="max-w-7xl mx-auto px-6 w-full relative z-10 pt-10">
          <div class="max-w-3xl transform translate-y-8 opacity-0 transition-all duration-700 slide-content">
             <div class="bg-white/10 backdrop-blur-md p-8 md:p-12 rounded-[2.5rem] border border-white/20 shadow-2xl">
               <h2 class="font-display text-4xl md:text-6xl font-black text-white mb-6 leading-[1.1] tracking-tight drop-shadow-sm">
                 {post.title}
               </h2>

               <p class="text-white/90 text-lg md:text-xl font-light mb-10 max-w-2xl leading-relaxed line-clamp-2">
                 {post.description}
               </p>

               <div class="flex items-center gap-6">
                  <a 
                    href={`/blog/${post.slug}`}
                    class="px-10 py-5 bg-amber-600 text-white rounded-2xl font-black uppercase tracking-[0.2em] text-xs hover:bg-white hover:text-forest transition-all transform hover:-translate-y-1 shadow-2xl shadow-amber-600/20 active:scale-95"
                  >
                     Baca Selengkapnya
                  </a>
               </div>
             </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Navigation Controls -->
  <div class="absolute bottom-12 left-6 right-6 md:left-12 md:right-12 z-30 flex justify-between items-end pointer-events-none">
     <!-- Indicators -->
     <div class="flex gap-3 pointer-events-auto">
        {posts.map((_, i) => (
          <button 
            data-index={i}
            class={`carousel-indicator h-1.5 transition-all duration-500 rounded-full bg-white/20 hover:bg-white/50 ${i === 0 ? 'w-12 bg-white' : 'w-4'}`}
            aria-label={`Go to slide ${i + 1}`}
          ></button>
        ))}
     </div>

     <!-- Prev/Next -->
     <div class="flex gap-4 pointer-events-auto">
        <button id="carousel-prev" class="w-14 h-14 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md flex items-center justify-center text-white hover:bg-white hover:text-forest transition-all transform hover:-translate-x-1 active:scale-95 shadow-xl">
           <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button id="carousel-next" class="w-14 h-14 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md flex items-center justify-center text-white hover:bg-white hover:text-forest transition-all transform hover:translate-x-1 active:scale-95 shadow-xl">
           <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
     </div>
  </div>
</section>

<style>
  .slide-active .slide-content {
    transform: translateY(0);
    opacity: 1;
  }
</style>

<script>
  function setupCarousel() {
    const container = document.getElementById('carousel-container');
    const slides = container?.children;
    const indicators = document.querySelectorAll('.carousel-indicator');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');

    if (!container || !slides || slides.length === 0) return;

    let currentIndex = 0;
    const totalSlides = slides.length;

    function goToSlide(index: number) {
      if (index < 0) index = totalSlides - 1;
      if (index >= totalSlides) index = 0;
      
      currentIndex = index;
      
      // Transform container
      container.style.transform = `translateX(-${currentIndex * 100}%)`;
      
      // Update indicators
      indicators.forEach((indicator, i) => {
        if (i === currentIndex) {
          indicator.classList.add('w-12', 'bg-white');
          indicator.classList.remove('w-4', 'bg-white/20');
        } else {
          indicator.classList.remove('w-12', 'bg-white');
          indicator.classList.add('w-4', 'bg-white/20');
        }
      });

      // Update slide active state for animations
      Array.from(slides).forEach((slide, i) => {
        if (i === currentIndex) {
          slide.classList.add('slide-active');
        } else {
          slide.classList.remove('slide-active');
        }
      });
    }

    // Initial state
    goToSlide(0);

    // Event Listeners
    prevBtn?.addEventListener('click', () => goToSlide(currentIndex - 1));
    nextBtn?.addEventListener('click', () => goToSlide(currentIndex + 1));
    
    indicators.forEach((indicator) => {
      indicator.addEventListener('click', () => {
        const index = parseInt(indicator.getAttribute('data-index') || '0');
        goToSlide(index);
      });
    });

    // Auto play
    let timer = setInterval(() => goToSlide(currentIndex + 1), 6000);

    // Pause on hover
    container.addEventListener('mouseenter', () => clearInterval(timer));
    container.addEventListener('mouseleave', () => {
       clearInterval(timer);
       timer = setInterval(() => goToSlide(currentIndex + 1), 6000);
    });
  }

  // Run on page load and swaps
  setupCarousel();
  document.addEventListener('astro:after-swap', setupCarousel);
</script>
