---
/**
 * HeroCarousel.astro — Retro Survival Manual 2.0
 * Props: unchanged — posts: any[]
 * Changes:
 *   - Removed: glassmorphism backdrop-blur card, rounded-[2.5rem], amber CTA
 *   - Added: ink overlay + muted gradient, flat card with ink border, mono labels
 *   - Indicators: horizontal dashes instead of pills
 *   - Nav buttons: square ink-border style, no blur
 */
import OptimizedImage from '../ui/OptimizedImage.astro';
import { calculateReadingTime } from '../../lib/markdown';

interface Props {
  posts: any[];
}
const { posts = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  air: 'Air', energi: 'Energi', pangan: 'Pangan',
  medis: 'Medis', keamanan: 'Keamanan', komunitas: 'Komunitas',
};
---

<section
  id="hero-section"
  style="position: relative; width: 100%; overflow: hidden; background: var(--ink); height: 580px;"
  aria-label="Artikel unggulan"
>
  <!-- Carousel track -->
  <div id="carousel-container" style="
    display: flex;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    height: 100%;
    width: 100%;
  ">
    {posts.map((post, index) => (
      <div style="min-width: 100%; height: 100%; position: relative; display: flex; align-items: flex-end;">

        <!-- BG image + overlays -->
        <div style="position: absolute; inset: 0; z-index: 0;">
          {(post.banner_image || post.cover_image) ? (
            <>
              <OptimizedImage
                image={post.banner_image || post.cover_image}
                alt={post.title}
                class="w-full h-full object-cover"
                style="filter: saturate(0.5) contrast(1.1); display: block;"
              />
              <!-- Flat dark overlays, no blur -->
              <div style="position:absolute;inset:0;background:rgba(42,34,24,0.6);"></div>
              <div style="position:absolute;inset:0;background:linear-gradient(to top, var(--ink) 0%, transparent 55%);"></div>
            </>
          ) : (
            <div style="width:100%;height:100%;background:var(--ink);"></div>
          )}
          <!-- Grid on hero -->
          <div style="
            position:absolute;inset:0;
            background-image:
              linear-gradient(rgba(143,175,143,0.04) 1px,transparent 1px),
              linear-gradient(90deg, rgba(143,175,143,0.04) 1px,transparent 1px);
            background-size:40px 40px;
            pointer-events:none;
          " aria-hidden="true"></div>
        </div>

        <!-- Content card — flat ink-border style -->
        <div style="
          position: relative; z-index: 10;
          width: 100%; padding: 0 3rem 3.5rem;
          max-width: 1200px; margin: 0 auto;
        " class="hero-content-padding">
          <div style="max-width: 700px;">

            <!-- Section label -->
            <div style="
              font-family: 'Share Tech Mono', monospace;
              font-size: 0.6rem;
              letter-spacing: 0.25em;
              color: var(--green-terminal);
              text-transform: uppercase;
              margin-bottom: 1rem;
              display: flex; align-items: center; gap: 0.75rem;
            ">
              <span style="display:inline-block;width:20px;height:1px;background:var(--green-terminal);"></span>
              {post.category ? categoryLabels[post.category] || post.category.toUpperCase() : 'ARKARA JURNAL'}
              <span style="color:var(--warm-grey-dark);">— SLIDE {String(index + 1).padStart(2, '0')}</span>
            </div>

            <!-- Title -->
            <h2 style="
              font-family: 'Barlow Condensed', sans-serif;
              font-size: clamp(1.8rem, 5vw, 3.8rem);
              font-weight: 800;
              text-transform: uppercase;
              color: var(--cream);
              line-height: 0.95;
              letter-spacing: -0.01em;
              margin-bottom: 1rem;
            ">{post.title}</h2>

            <!-- Description -->
            {post.description && (
              <p style="
                font-family: 'Barlow', sans-serif;
                font-size: 0.9rem;
                color: var(--warm-grey);
                line-height: 1.65;
                margin-bottom: 1.5rem;
                max-width: 480px;
              ">{post.description}</p>
            )}

            <!-- CTA -->
            <a
              href={`/blog/${post.slug}`}
              style="
                font-family: 'Share Tech Mono', monospace;
                font-size: 0.72rem;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                padding: 0.75rem 1.6rem;
                background: var(--ink);
                color: var(--green-terminal);
                border: 2px solid var(--green-terminal);
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                transition: all 0.15s;
              "
              onmouseover="this.style.background='var(--green-dark)';this.style.transform='translate(-2px,-2px)';this.style.boxShadow='4px 4px 0 var(--green-terminal)'"
              onmouseout="this.style.background='var(--ink)';this.style.transform='';this.style.boxShadow=''"
            >
              ▶ BACA SELENGKAPNYA
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- ── CAROUSEL CONTROLS ──────────────────────────────── -->
  <div style="
    position: absolute; bottom: 1.5rem; left: 3rem; right: 3rem;
    display: flex; justify-content: space-between; align-items: center;
    z-index: 20; pointer-events: none;
  " class="carousel-controls-padding">

    <!-- Dash indicators -->
    <div style="display: flex; gap: 0.5rem; pointer-events: auto;" id="carousel-indicators">
      {posts.map((_, i) => (
        <button
          data-index={i}
          class="carousel-dot"
          style={`
            height: 2px;
            border: none; cursor: pointer; padding: 4px 0;
            background: transparent;
            transition: width 0.3s;
          `}
          aria-label={`Slide ${i + 1}`}
        >
          <span style={`
            display: block; height: 2px;
            background: ${i === 0 ? 'var(--green-terminal)' : 'rgba(143,175,143,0.3)'};
            width: ${i === 0 ? '32px' : '16px'};
            transition: all 0.3s;
          `}></span>
        </button>
      ))}
    </div>

    <!-- Prev / Next — square ink style -->
    <div style="display: flex; gap: 0.5rem; pointer-events: auto;">
      <button id="carousel-prev" style="
        width: 40px; height: 40px;
        background: var(--ink);
        border: 2px solid var(--green-terminal);
        color: var(--green-terminal);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: all 0.15s;
        font-family: monospace; font-size: 0.9rem;
      "
      onmouseover="this.style.background='var(--green-dark)'"
      onmouseout="this.style.background='var(--ink)'"
      aria-label="Slide sebelumnya">◀</button>

      <button id="carousel-next" style="
        width: 40px; height: 40px;
        background: var(--ink);
        border: 2px solid var(--green-terminal);
        color: var(--green-terminal);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: all 0.15s;
        font-family: monospace; font-size: 0.9rem;
      "
      onmouseover="this.style.background='var(--green-dark)'"
      onmouseout="this.style.background='var(--ink)'"
      aria-label="Slide berikutnya">▶</button>
    </div>
  </div>
</section>

<style>
  @media (max-width: 640px) {
    .hero-content-padding { padding: 0 1.5rem 3rem !important; }
    .carousel-controls-padding { left: 1.5rem !important; right: 1.5rem !important; }
  }
</style>

<script>
  function setupCarousel() {
    const container = document.getElementById('carousel-container');
    const indicators = document.querySelectorAll('.carousel-dot span');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');
    const dotBtns = document.querySelectorAll('.carousel-dot');

    if (!container) return;
    const slides = container.children;
    const total = slides.length;
    if (total === 0) return;

    let current = 0;

    function goTo(index: number) {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
      current = index;
      (container as HTMLElement).style.transform = `translateX(-${current * 100}%)`;

      indicators.forEach((ind, i) => {
        const span = ind as HTMLElement;
        span.style.background  = i === current ? 'var(--green-terminal)' : 'rgba(143,175,143,0.3)';
        span.style.width       = i === current ? '32px' : '16px';
      });
    }

    goTo(0);
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dotBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        goTo(parseInt(btn.getAttribute('data-index') || '0'));
      });
    });

    let timer = setInterval(() => goTo(current + 1), 6000);
    container.addEventListener('mouseenter', () => clearInterval(timer));
    container.addEventListener('mouseleave', () => {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 6000);
    });
  }

  setupCarousel();
  document.addEventListener('astro:after-swap', setupCarousel);
</script>
