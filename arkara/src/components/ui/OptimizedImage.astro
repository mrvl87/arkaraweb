---
import { rewriteMediaUrl } from '../../lib/media';

interface Props {
  image?: any;       // The JSON object from Supabase or string fallback
  alt?: string;      // Fallback alt text if not in JSON
  class?: string;    // CSS classes
  loading?: 'lazy' | 'eager'; // Priority loading
  aspectRatio?: string; // Optional enforced aspect ratio class e.g., 'aspect-video'
  sizes?: string; // HTML sizes attribute
  transparent?: boolean; // If true, disable placeholder logic and change default fit
  fetchpriority?: 'high' | 'low' | 'auto'; // Priority for LCP
  maxSrcSetWidth?: number; // Caps desktop candidates to avoid oversized downloads
  mobileMaxSrcSetWidth?: number; // Caps mobile candidates independently
  mobileSizes?: string; // Optional mobile-only sizes source
  targetWidths?: number[]; // Optional exact desktop widths generated by the media proxy
  mobileTargetWidths?: number[]; // Optional exact mobile widths generated by the media proxy
  quality?: number; // Optional media proxy quality for generated variants
}

const { 
  image, 
  alt = '', 
  class: className = '', 
  loading = 'lazy',
  aspectRatio = '',
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  transparent = false,
  fetchpriority = 'auto',
  maxSrcSetWidth = 1200,
  mobileMaxSrcSetWidth,
  mobileSizes = sizes,
  targetWidths,
  mobileTargetWidths,
  quality = 74
} = Astro.props;

// If no image is provided
if (!image) {
  return null;
}

// Ensure we have an object to work with
const isStringUrl = typeof image === 'string';

// Build the attributes based on whether it's our new JSON format or legacy string URL
let src = rewriteMediaUrl(isStringUrl ? image : image.url || '');
let srcSet = '';
let mobileSrcSet = '';
let altText = isStringUrl ? alt : (image.alt_text || alt);
let blurhash = !isStringUrl && image.blurhash ? image.blurhash : '';
let dominantColor = !isStringUrl && image.dominant_color ? image.dominant_color : '';
let hasFormats = !isStringUrl && image.formats && Object.keys(image.formats).length > 0;



const isTransparent = transparent || (image && image.formats && image.formats.has_alpha === 'true');

// Determine object-fit
// If transparent is explicitly true, default to contain unless cover is specified.
// Else default to cover unless contain is specified.
const objectFit = isTransparent 
  ? (className.includes('object-cover') ? 'object-cover' : 'object-contain')
  : (className.includes('object-contain') ? 'object-contain' : 'object-cover');

if (hasFormats) {
  const candidates = [
    image.formats.sm ? { url: image.formats.sm, width: 400 } : null,
    image.formats.md ? { url: image.formats.md, width: 800 } : null,
    image.formats.lg ? { url: image.formats.lg, width: 1200 } : null,
    image.formats.original ? { url: image.formats.original, width: 2000 } : null,
  ].filter(Boolean) as Array<{ url: string; width: number }>;

  function pickSourceForWidth(width: number) {
    return candidates.find((candidate) => candidate.width >= width) || candidates[candidates.length - 1];
  }

  function normalizeWidths(widths: number[], maxWidth?: number) {
    return [...new Set(widths)]
      .filter((width) => width > 0 && (!maxWidth || width <= maxWidth))
      .sort((a, b) => a - b);
  }

  function buildSrcSet(maxWidth?: number, widths?: number[]) {
    if (widths?.length) {
      const selectedWidths = normalizeWidths(widths, maxWidth);

      return selectedWidths
        .map((width) => `${rewriteMediaUrl(pickSourceForWidth(width).url, { width, quality })} ${width}w`)
        .join(', ');
    }

    const allowed = candidates.filter((candidate) => !maxWidth || candidate.width <= maxWidth);
    const selected = allowed.length > 0 ? allowed : candidates.slice(0, 1);

    return selected
      .map((candidate) => `${rewriteMediaUrl(candidate.url)} ${candidate.width}w`)
      .join(', ');
  }

  srcSet = buildSrcSet(maxSrcSetWidth, targetWidths);
  mobileSrcSet = mobileMaxSrcSetWidth ? buildSrcSet(mobileMaxSrcSetWidth, mobileTargetWidths) : '';
  
  // Use md as the default fallback src if available
  if (targetWidths?.length) {
    const fallbackWidth = normalizeWidths(targetWidths, maxSrcSetWidth).at(-1);
    const fallbackSource = fallbackWidth ? pickSourceForWidth(fallbackWidth) : image.formats.md;
    src = fallbackWidth && fallbackSource
      ? rewriteMediaUrl(fallbackSource.url, { width: fallbackWidth, quality })
      : rewriteMediaUrl(image.formats.md || image.formats.sm || image.formats.original);
  } else if (image.formats.md) {
    src = rewriteMediaUrl(image.formats.md);
  }
} else if (src) {
  // Fallback to original src if no formats exist
  srcSet = ''; 
}

// Styling for placeholder
const placeholderStyle = isTransparent ? '' : (dominantColor ? `background-color: ${dominantColor};` : '');
const showBlurhash = !isTransparent && blurhash;
---

{src && (
  <div class={`relative overflow-hidden ${aspectRatio} ${className}`} style={placeholderStyle}>
    {/* Optional Blurhash Background (very lightweight base64) */}
    {showBlurhash && (
      <img 
        src={blurhash} 
        alt="" 
        class={`absolute inset-0 w-full h-full ${objectFit} blur-xl opacity-50 scale-110`}
        aria-hidden="true" 
      />
    )}
    
    {/* Actual Output */}
    {hasFormats ? (
       <picture>
         {/* We can explicitly set type image/webp since backend uses webp for these formats */}
         {mobileSrcSet && (
           <source media="(max-width: 640px)" type="image/webp" srcset={mobileSrcSet} sizes={mobileSizes} />
         )}
         <source type="image/webp" srcset={srcSet} sizes={sizes} />
         <img
           src={src}
           alt={altText}
           loading={loading}
           decoding={loading === 'eager' ? 'sync' : 'async'}
           fetchpriority={fetchpriority}
           class={`relative z-10 w-full h-full ${objectFit} transition-opacity duration-300`}
         />
       </picture>
    ) : (
      <img
        src={src}
        alt={altText}
        loading={loading}
        decoding={loading === 'eager' ? 'sync' : 'async'}
        fetchpriority={fetchpriority}
        class={`relative z-10 w-full h-full ${objectFit}`}
      />
    )}
  </div>
)}
