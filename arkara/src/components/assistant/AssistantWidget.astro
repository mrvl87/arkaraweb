---
import type { AssistantMode } from "../../lib/assistant/contracts";

const {
  initialMode
}: {
  initialMode?: AssistantMode;
} = Astro.props;

const assistantHref = initialMode
  ? `/assistant?mode=${encodeURIComponent(initialMode)}`
  : '/assistant';
---

<div class="assistant-lazy-root" data-assistant-lazy-root>
  <a class="assistant-lazy-trigger" href={assistantHref} aria-label="Buka Arkara AI Assistant">
    <span class="assistant-lazy-trigger__eyebrow">Arkara AI Assistant</span>
    <span class="assistant-lazy-trigger__title">Buka assistant</span>
    <span class="assistant-lazy-trigger__meta">Checklist, ringkasan, dan langkah cepat.</span>
  </a>
</div>

<style>
  .assistant-lazy-trigger {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    width: min(280px, calc(100vw - 2rem));
    padding: 0.9rem 1rem;
    background: var(--ink);
    border: 3px solid var(--green-terminal);
    box-shadow: 5px 5px 0 var(--green-terminal);
    color: var(--cream);
    cursor: pointer;
    display: block;
    text-align: left;
    text-decoration: none;
  }

  .assistant-lazy-trigger__eyebrow,
  .assistant-lazy-trigger__meta {
    display: block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    color: var(--green-terminal);
    text-transform: uppercase;
  }

  .assistant-lazy-trigger__title {
    display: block;
    margin: 0.2rem 0;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1;
    text-transform: uppercase;
  }

  .assistant-lazy-trigger__meta {
    color: var(--warm-grey);
    line-height: 1.4;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  @media (max-width: 640px) {
    .assistant-lazy-trigger {
      right: 0.75rem;
      bottom: 0.75rem;
      width: min(240px, calc(100vw - 1.5rem));
      padding: 0.75rem 0.85rem;
    }
  }
</style>
