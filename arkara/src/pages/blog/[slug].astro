---
import { getPostBySlug } from '../../lib/content';
import { renderMarkdown, extractHeadings } from '../../lib/markdown';
import PostLayout from '../../layouts/PostLayout.astro';
import NotFoundPage from '../../components/system/NotFoundPage.astro';

const { slug } = Astro.params;
const post = slug ? await getPostBySlug(slug) : null;
const postNotFound = !post;

if (postNotFound) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not Found';
}

const htmlContent = renderMarkdown(post?.content || '');
const headings = extractHeadings(htmlContent);
---

{postNotFound ? (
  <NotFoundPage
    pageTitle="Artikel Tidak Ditemukan"
    pageDescription="Artikel yang Anda cari tidak tersedia atau sudah dipindahkan."
    message="Slug artikel ini tidak tersedia lagi di publikasi aktif Arkara. Periksa kembali URL atau kembali ke arsip blog."
    fallbackHref="/blog"
    fallbackLabel="Arsip Blog"
    homeHref="/blog"
    homeLabel="Lihat Blog"
  />
) : (
  <PostLayout
    title={post.meta_title || post.title}
    description={post.meta_desc || post.description}
    publishDate={post.published_at}
    category="ARKARA JURNAL"
    coverImage={post.banner_image || post.cover_image}
    headings={headings}
    content={post.content || ''}
    currentSlug={post.slug}
    contentType="blog"
  >
    <div set:html={htmlContent} />
  </PostLayout>
)}
