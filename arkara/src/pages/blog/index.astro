---
/**
 * Blog Listing Page
 */

import { getPublishedPosts } from '../../lib/content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';

const selectedCategory = Astro.url.searchParams.get('category') || undefined;

const sortedPosts = await getPublishedPosts({ category: selectedCategory });

const categories = ['air', 'energi', 'pangan', 'medis', 'keamanan', 'komunitas'];
const categoryLabels: Record<string, string> = {
  air: 'Air',
  energi: 'Energi',
  pangan: 'Pangan',
  medis: 'Medis',
  keamanan: 'Keamanan',
  komunitas: 'Komunitas',
};
---

<BaseLayout title="Blog">
  <!-- Hero Section -->
  <section class="bg-forest pt-24 pb-48 md:pt-32 md:pb-64 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none bg-[radial-gradient(#E6D8B5_1.5px,transparent_1.5px)] [background-size:24px_24px]"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
      <h1 class="font-display text-5xl md:text-8xl font-black text-sand mb-6 tracking-tight leading-[1.1]">
        Arkara <span class="text-amber-500 italic">Jurnal</span>
      </h1>
      <p class="text-sand/60 text-lg md:text-2xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Kumpulan pengetahuan, strategi, dan jurnal mendalam untuk membangun kemandirian di era ketidakpastian.
      </p>

      <!-- Category Filter -->
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="/blog"
          class={`px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] transition-all transform hover:-translate-y-1 active:scale-95 shadow-lg ${
            !selectedCategory
              ? 'bg-amber-600 text-white shadow-amber-600/30 ring-4 ring-amber-600/20'
              : 'bg-white/10 text-sand hover:bg-white/20 hover:text-white border border-white/10'
          }`}
        >
          Semua
        </a>
        {categories.map((cat) => (
          <a
            href={`/blog?category=${cat}`}
            class={`px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] transition-all transform hover:-translate-y-1 active:scale-95 shadow-lg ${
              selectedCategory === cat
                ? 'bg-amber-600 text-white shadow-amber-600/30 ring-4 ring-amber-600/20'
                : 'bg-white/10 text-sand hover:bg-white/20 hover:text-white border border-white/10'
            }`}
          >
            {categoryLabels[cat]}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="max-w-7xl mx-auto px-6 -mt-32 md:-mt-48 pb-64 relative z-20">
    {sortedPosts.length > 0 ? (
      <>
        {/* Featured Post (Only on Page 1 / Unfiltered) */}
        {!selectedCategory && sortedPosts.length > 0 && (
          <FeaturedPost 
             post={sortedPosts[0]} 
             categoryLabel={categoryLabels[sortedPosts[0].category] || sortedPosts[0].category} 
          />
        )}

        <div class="flex items-center gap-6 mb-12">
           <h2 class="font-display text-3xl font-black text-forest whitespace-nowrap">
              {selectedCategory ? categoryLabels[selectedCategory] : 'Artikel Terbaru'}
           </h2>
           <div class="h-1 bg-stone/10 flex-grow rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
          {(selectedCategory ? sortedPosts : sortedPosts.slice(1)).map((post) => (
            <PostCard
              title={post.title}
              excerpt={post.description || ''}
              category={categoryLabels[post.category] || post.category}
              date={post.published_at || ''}
              slug={post.slug}
              content={post.content || ''}
              image={post.thumbnail_image || post.cover_image}
            />
          ))}
        </div>
      </>
    ) : (
      <!-- Empty State -->
      <div class="bg-white border border-stone/10 rounded-3xl p-24 text-center shadow-xl shadow-forest/5">
        <div class="text-8xl mb-8 transform hover:scale-110 transition-transform cursor-default">📭</div>
        <h2 class="font-display text-4xl font-black text-forest mb-4">Jurnal Belum Tersedia</h2>
        <p class="text-stone/60 max-w-md mx-auto mb-10 text-lg leading-relaxed font-light">
          Maaf, belum ada artikel untuk kategori <strong>{categoryLabels[selectedCategory!] || selectedCategory}</strong> saat ini. Silakan pantengin terus atau cek kategori lain.
        </p>
        <a href="/blog" class="inline-block py-4 px-10 bg-forest text-sand rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-amber-600 transition-all shadow-lg hover:shadow-amber-600/20">
           Tampilkan Semua Artikel
        </a>
      </div>
    )}
  </section>
</BaseLayout>
