---
import { resolvePublishedPanduanRoute } from '../../lib/content';
import { renderMarkdown, extractHeadings } from '../../lib/markdown';
import PostLayout from '../../layouts/PostLayout.astro';
import NotFoundPage from '../../components/system/NotFoundPage.astro';

const { slug } = Astro.params;
const resolvedRoute = slug ? await resolvePublishedPanduanRoute(slug) : { kind: 'not_found' as const };

if (resolvedRoute.kind === 'redirect') {
  Astro.response.status = 301;
  Astro.response.statusText = 'Moved Permanently';
  Astro.response.headers.set('Location', resolvedRoute.location);
}

const guide = resolvedRoute.kind === 'panduan' ? resolvedRoute.panduan : null;
const guideNotFound = resolvedRoute.kind === 'not_found';

if (guideNotFound) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not Found';
}

const categoryLabels: Record<string, string> = {
  air: 'Air',
  energi: 'Energi',
  pangan: 'Pangan',
  medis: 'Medis',
  keamanan: 'Keamanan',
  komunitas: 'Komunitas',
};

const htmlContent = renderMarkdown(guide?.content || '');
const headings = extractHeadings(htmlContent);
---

{resolvedRoute.kind === 'redirect' ? null : guideNotFound ? (
  <NotFoundPage
    pageTitle="Panduan Tidak Ditemukan"
    pageDescription="Panduan yang Anda cari tidak tersedia atau sudah dipindahkan."
    message="Slug panduan ini tidak tersedia lagi di publikasi aktif Arkara. Periksa kembali URL atau kembali ke daftar panduan."
    fallbackHref="/panduan"
    fallbackLabel="Daftar Panduan"
    homeHref="/panduan"
    homeLabel="Lihat Panduan"
  />
) : (
  <PostLayout
    title={guide.title}
    description={`Panduan Teknis: Bab ${guide.bab_ref || '-'}`}
    category={categoryLabels[guide.category] || guide.category || 'PANDUAN'}
    publishDate={new Date().toISOString()} 
    coverImage={guide.banner_image || guide.cover_image}
    canonicalHref={`/panduan/${guide.slug}`}
    headings={headings}
    content={guide.content || ''}
    currentSlug={guide.slug}
    contentType="panduan"
    quickAnswer={guide.quick_answer}
    keyTakeaways={guide.key_takeaways || []}
    faq={guide.faq || []}
    editorialFormat={guide.editorial_format || 'legacy'}
  >
    <div class="flex gap-4 text-sm font-mono mb-8 bg-parchment p-4 rounded-xl border border-stone/10">
      {guide.bab_ref && (
        <span>REF: <strong class="text-moss">{guide.bab_ref}</strong></span>
      )}
      {guide.qr_slug && (
        <span>QR_CODE: <strong class="text-amber-600">{guide.qr_slug}</strong></span>
      )}
    </div>
    
    <div set:html={htmlContent} />
  </PostLayout>
)}
