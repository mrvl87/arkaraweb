---
export const prerender = true;
/**
 * index.astro — Homepage — Retro Survival Manual 2.0
 * Data fetching: unchanged (getRecentPosts from lib/content)
 * Changes:
 * - Warning band ticker (new — replaces nothing)
 * - Article grid: card-ink style, section label
 * - Categories: flat ink-border panels, no rounded, no hover scale
 * - CTA section: dark ink bg, flat box-shadow (no blur)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/blog/PostCard.astro';
import HeroCarousel from '../components/home/HeroCarousel.astro';
import MascotSection from '../components/home/MascotSection.astro';
import { getRecentPosts, getCtaSection, getSiteSettings, getHeroSection } from '../lib/content';

const [recentPosts, cta, settings, hero] = await Promise.all([
  getRecentPosts(5),
  getCtaSection(),
  getSiteSettings(),
  getHeroSection(),
]);
const displayPosts = recentPosts.slice(0, 3);

const categories = [
  { name: 'Air',       slug: 'air',       icon: '💧' },
  { name: 'Energi',    slug: 'energi',    icon: '⚡' },
  { name: 'Pangan',    slug: 'pangan',    icon: '🌾' },
  { name: 'Medis',     slug: 'medis',     icon: '⚕️' },
  { name: 'Keamanan',  slug: 'keamanan',  icon: '🛡️' },
  { name: 'Komunitas', slug: 'komunitas', icon: '👥' },
];

const tickerRaw = settings['ticker_items'] 
const tickerItems = tickerRaw 
  ? tickerRaw.split('|').map(s => s.trim())
  : [
    'Persiapan adalah investasi terbaik',
    'Bukan panik — tapi siap',
    'Pengetahuan tidak pernah basi',
    'Siap sebelum perlu',
    'Survival bukan gaya hidup — ini kebutuhan',
  ];
const tickerDouble = [...tickerItems, ...tickerItems];
---

<BaseLayout title="Beranda">

  <!-- ── HERO SECTION (GRID 2 COLUMNS) ─────────────────── -->
  <div class="grid grid-cols-1 md:grid-cols-[1fr_400px] border-b-4 border-zinc-900 bg-zinc-900 overflow-hidden">
    <HeroCarousel posts={recentPosts} />
    <MascotSection 
      mascotImage={hero?.mascot_image} 
      speechText={hero?.mascot_speech_text} 
      tagline={hero?.mascot_tagline} 
    />
  </div>

  <!-- ── WARNING BAND TICKER ───────────────────────────── -->
  <div style="
    background: var(--yellow-manual);
    border-top: 3px solid var(--ink);
    border-bottom: 3px solid var(--ink);
    padding: 0.6rem 0;
    overflow: hidden;
    position: relative;
    z-index: 2;
  " aria-hidden="true">
    <div style="
      display: flex;
      gap: 3rem;
      animation: scroll-ticker 22s linear infinite;
      white-space: nowrap;
    ">
      {tickerDouble.map(item => (
        <span style="
          font-family: 'Barlow Condensed', sans-serif;
          font-weight: 700;
          font-size: 0.78rem;
          letter-spacing: 0.2em;
          color: var(--ink);
          text-transform: uppercase;
          display: inline-flex;
          align-items: center;
          gap: 1rem;
        ">
          <span style="color:var(--red-warning);font-size:0.5rem;">◆</span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ── RECENT ARTICLES ───────────────────────────────── -->
  <section style="
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    position: relative;
    z-index: 2;
  ">
    <!-- Section header -->
    <div style="
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 2.5rem;
      gap: 1.5rem;
      flex-wrap: wrap;
    ">
      <div>
        <h1 style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0;">
          Arkara — Survive with Knowledge | Pengetahuan Survival Indonesia
        </h1>
        <div style="
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.6rem;
          letter-spacing: 0.25em;
          color: var(--warm-grey);
          text-transform: uppercase;
          display: flex; align-items: center; gap: 0.75rem;
          margin-bottom: 0.75rem;
        ">
          <span style="display:inline-block;width:20px;height:1px;background:var(--green-terminal);"></span>
          SECTION A — ARTIKEL TERBARU
        </div>
        <h2 style="
          font-family: 'Barlow Condensed', sans-serif;
          font-size: clamp(2rem, 4vw, 3rem);
          font-weight: 800;
          text-transform: uppercase;
          color: var(--ink);
          line-height: 1;
          margin: 0;
        ">JURNAL<br><span style="font-family:'Special Elite',cursive;text-transform:none;font-size:0.75em;color:var(--green-muted);">Teranyar</span></h2>
      </div>

      <a href="/blog" style="
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.7rem 1.4rem;
        background: transparent;
        color: var(--ink);
        border: 2px solid var(--ink);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.15s;
        white-space: nowrap;
      "
      onmouseover="this.style.background='var(--ink)';this.style.color='var(--cream)';this.style.transform='translate(-2px,-2px)';this.style.boxShadow='4px 4px 0 var(--ink)'"
      onmouseout="this.style.background='transparent';this.style.color='var(--ink)';this.style.transform='';this.style.boxShadow=''"
      >LIHAT SEMUA →</a>
    </div>

    <!-- Posts grid -->
    {recentPosts.length > 0 ? (
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; background: var(--ink); border: 3px solid var(--ink);" class="posts-grid">
        {displayPosts.map((post) => (
          <div style="background: var(--cream);">
            <PostCard
              title={post.title}
              excerpt={post.description || ''}
              category={post.category}
              date={post.published_at || ''}
              slug={post.slug}
              content={post.content || ''}
              image={post.thumbnail_image || post.cover_image}
            />
          </div>
        ))}
      </div>
    ) : (
      <div style="
        background: var(--paper);
        border: 3px solid var(--ink);
        padding: 5rem 2rem;
        text-align: center;
      ">
        <p style="font-family:'Special Elite',cursive;font-size:1.2rem;color:var(--warm-grey);">Belum ada jurnal yang diterbitkan.</p>
      </div>
    )}
  </section>

  <!-- ── PILAR PENGETAHUAN ──────────────────────────────── -->
  <section style="
    background: var(--ink);
    border-top: 3px solid var(--green-terminal);
    border-bottom: 3px solid var(--green-terminal);
    padding: 4rem 2rem;
    position: relative;
    overflow: hidden;
    z-index: 2;
  ">
    <!-- Watermark text -->
    <div style="
      position: absolute; bottom: -1rem; right: 1rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 8rem;
      color: rgba(143,175,143,0.04);
      letter-spacing: -0.03em;
      pointer-events: none;
      line-height: 1;
    " aria-hidden="true">MODUL</div>

    <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">

      <!-- Section header -->
      <div style="margin-bottom: 2.5rem;">
        <div style="
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.6rem;
          letter-spacing: 0.25em;
          color: var(--green-terminal);
          text-transform: uppercase;
          display: flex; align-items: center; gap: 0.75rem;
          margin-bottom: 0.75rem;
        ">
          <span style="display:inline-block;width:20px;height:1px;background:var(--green-terminal);"></span>
          SECTION B — TOPIK UTAMA
        </div>
        <h2 style="
          font-family: 'Barlow Condensed', sans-serif;
          font-size: clamp(2rem, 4vw, 3rem);
          font-weight: 800;
          text-transform: uppercase;
          color: var(--cream);
          line-height: 1;
          margin: 0;
        ">PILAR<br>PENGETAHUAN</h2>
      </div>

      <!-- Category grid — flat ink-border panels -->
      <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 1.5px; background: var(--green-terminal); border: 2px solid var(--green-terminal);" class="cat-grid">
        {categories.map((cat) => (
          <a href={`/panduan?category=${cat.slug}`} style="
            background: var(--ink);
            padding: 1.5rem 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            transition: background 0.15s;
            border: none;
          "
          onmouseover="this.style.background='var(--green-dark)'"
          onmouseout="this.style.background='var(--ink)'"
          >
            <span style="font-size: 2rem; filter: saturate(0.7);">{cat.icon}</span>
            <span style="
              font-family: 'Barlow Condensed', sans-serif;
              font-size: 0.85rem;
              font-weight: 700;
              text-transform: uppercase;
              letter-spacing: 0.05em;
              color: var(--green-terminal);
              text-align: center;
            ">{cat.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA / PANDUAN ─────────────────────────────────── -->
  <section style="
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    position: relative;
    z-index: 2;
  ">
    <div style="
      background: var(--ink);
      border: 3px solid var(--green-terminal);
      box-shadow: 8px 8px 0 var(--green-terminal);
      padding: 3.5rem;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: center;
      position: relative;
      overflow: hidden;
    " class="cta-grid">
      <!-- Background watermark -->
      <div style="
        position:absolute;right:-1rem;bottom:-1rem;
        font-family:'Barlow Condensed',sans-serif;
        font-size:10rem;
        font-weight:800;
        color:rgba(143,175,143,0.04);
        line-height:1;
        pointer-events:none;
        letter-spacing:-0.04em;
      " aria-hidden="true">PANDUAN</div>

      <div style="position:relative;z-index:1;">
        <div style="
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.58rem;
          letter-spacing: 0.2em;
          color: var(--green-terminal);
          text-transform: uppercase;
          margin-bottom: 0.75rem;
          display: flex; align-items: center; gap: 0.5rem;
        ">
          <span style="display:inline-block;width:16px;height:1px;background:var(--green-terminal);"></span>
          AKSES OFFLINE TERSEDIA
        </div>
        <h2 style="
          font-family: 'Barlow Condensed', sans-serif;
          font-size: clamp(1.8rem, 4vw, 3rem);
          font-weight: 800;
          text-transform: uppercase;
          color: var(--cream);
          line-height: 0.95;
          margin-bottom: 1rem;
        ">
          {cta?.headline || 'KOLEKSI'}
          <br>
          <span style="font-family:'Special Elite',cursive;text-transform:none;color:var(--yellow-manual);">
            {cta?.body_text ? 'Panduan Taktis' : 'Panduan Taktis'} 
          </span>
        </h2>
        <p style="
          font-size: 0.85rem;
          color: var(--warm-grey);
          max-width: 400px;
          line-height: 1.65;
        ">
          {cta?.body_text || 'Instruksi teknis yang terhubung dengan Buku Pegangan Krisis. Dapat dibaca offline, dirancang untuk situasi darurat.'}
        </p>
      </div>

      <div style="position:relative;z-index:1;flex-shrink:0;">
        <a href={cta?.button_href || '/panduan'} style="
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.72rem;
          letter-spacing: 0.15em;
          text-transform: uppercase;
          padding: 1rem 2rem;
          background: var(--green-terminal);
          color: var(--ink);
          border: 2px solid var(--green-terminal);
          text-decoration: none;
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          font-weight: 700;
          white-space: nowrap;
          transition: all 0.15s;
        "
        onmouseover="this.style.background='var(--yellow-manual)';this.style.borderColor='var(--yellow-manual)';this.style.transform='translate(-2px,-2px)';this.style.boxShadow='4px 4px 0 var(--green-terminal)'"
        onmouseout="this.style.background='var(--green-terminal)';this.style.borderColor='var(--green-terminal)';this.style.transform='';this.style.boxShadow=''"
        >▶ {cta?.button_label || 'MULAI PELAJARI'}</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 900px) {
    .posts-grid { grid-template-columns: 1fr !important; }
    .cat-grid   { grid-template-columns: repeat(3, 1fr) !important; }
    .cta-grid   { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 640px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
</style>
