---
/**
 * index.astro — Homepage — Retro Survival Manual 2.0
 * Data fetching: unchanged (getRecentPosts from lib/content)
 * Changes:
 * - Warning band ticker (new — replaces nothing)
 * - Article grid: card-ink style, section label
 * - Categories: flat ink-border panels, no rounded, no hover scale
 * - CTA section: dark ink bg, flat box-shadow (no blur)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/ui/OptimizedImage.astro';
import PostCard from '../components/blog/PostCard.astro';
import HeroCarousel from '../components/home/HeroCarousel.astro';
import MascotSection from '../components/home/MascotSection.astro';
import SearchAutosuggest from '../components/SearchAutosuggest.astro';
import { getRecentPosts, getCtaSection, getSiteSettings, getHeroSection } from '../lib/content';

const [recentPosts, cta, settings, hero] = await Promise.all([
  getRecentPosts(5),
  getCtaSection(),
  getSiteSettings(),
  getHeroSection(),
]);
const displayPosts = recentPosts.slice(0, 3);

const categories = [
  { name: 'Air',       slug: 'air',       icon: '💧' },
  { name: 'Energi',    slug: 'energi',    icon: '⚡' },
  { name: 'Pangan',    slug: 'pangan',    icon: '🌾' },
  { name: 'Medis',     slug: 'medis',     icon: '⚕️' },
  { name: 'Keamanan',  slug: 'keamanan',  icon: '🛡️' },
  { name: 'Komunitas', slug: 'komunitas', icon: '👥' },
];

const tickerRaw = settings['ticker_items'] 
const tickerItems = tickerRaw 
  ? tickerRaw.split('|').map(s => s.trim())
  : [
    'Persiapan adalah investasi terbaik',
    'Bukan panik — tapi siap',
    'Pengetahuan tidak pernah basi',
    'Siap sebelum perlu',
    'Survival bukan gaya hidup — ini kebutuhan',
  ];
const tickerDouble = [...tickerItems, ...tickerItems];
const featuredPost = displayPosts[0];
const continuePosts = recentPosts.slice(1, 3);
const editorPosts = recentPosts.slice(2, 5);
const categoryLabels: Record<string, string> = {
  air: 'Air',
  energi: 'Energi',
  pangan: 'Pangan',
  medis: 'Medis',
  keamanan: 'Keamanan',
  komunitas: 'Komunitas',
  panduan: 'Panduan',
};
const guideCategories = [
  { label: 'Panduan', href: '/panduan', icon: 'guide' },
  { label: 'Energi', href: '/panduan?category=energi', icon: 'energy' },
  { label: 'Air', href: '/panduan?category=air', icon: 'water' },
  { label: 'Pangan', href: '/panduan?category=pangan', icon: 'food' },
  { label: 'Medis', href: '/panduan?category=medis', icon: 'medical' },
  { label: 'Komunitas', href: '/panduan?category=komunitas', icon: 'community' },
];
const fixedGuideCategory = guideCategories[0];
const scrollGuideCategories = guideCategories.slice(1);

function getPostImage(post: any) {
  return post?.thumbnail_image || post?.banner_image || post?.cover_image;
}

function getCategoryLabel(category?: string | null) {
  if (!category) return 'Artikel';
  return categoryLabels[category] || category;
}
---

<BaseLayout title="Beranda">
  <nav class="mobile-topic-rail" aria-label="Topik cepat">
    <a href="/blog">Terbaru</a>
    <a href="/panduan">Panduan</a>
    {categories.map((cat) => (
      <a href={`/panduan?category=${cat.slug}`}>{cat.name}</a>
    ))}
  </nav>

  <section class="mobile-home-screen" aria-label="Beranda Arkara mobile">
    <header class="mobile-home-header">
      <a href="/" class="mobile-brand">Arkaraweb</a>
      <div class="mobile-header-actions" aria-label="Aksi cepat">
        <a href="/blog" aria-label="Artikel tersimpan">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 4h12v17l-6-4-6 4V4Z"/></svg>
        </a>
        <a href="#mobile-search" aria-label="Cari">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        </a>
      </div>
    </header>

    <SearchAutosuggest id="mobile-search" variant="mobile" placeholder="Cari panduan..." />

    <nav class="mobile-home-tabs" aria-label="Kategori panduan">
      <a href={fixedGuideCategory.href} class="mobile-category-fixed">
        <span class="mobile-category-logo" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M6 4.5h8.5A3.5 3.5 0 0 1 18 8v11.5H8.5A2.5 2.5 0 0 0 6 22V4.5Z" />
            <path d="M6 4.5A2.5 2.5 0 0 1 8.5 2H18v17.5" />
            <path d="M9 8h6M9 11h5" />
          </svg>
        </span>
        <em>{fixedGuideCategory.label}</em>
      </a>

      <div class="mobile-category-scroll">
        {scrollGuideCategories.map((category) => (
          <a href={category.href} aria-label={category.label}>
          <span class="mobile-category-logo" aria-hidden="true">
            {category.icon === 'energy' && (
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M13.3 2 5 13.1h6.2L9.9 22 19 9.8h-6.4L13.3 2Z" />
              </svg>
            )}
            {category.icon === 'water' && (
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.5c-3.5 4.1-5.3 7.2-5.3 9.8a5.3 5.3 0 1 0 10.6 0c0-2.6-1.8-5.7-5.3-9.8Z" />
              </svg>
            )}
            {category.icon === 'food' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M6 20c7.4-.8 11.4-4.9 12-12" />
                <path d="M7 17c-.5-4.7 2.3-8.4 7.5-10.7 1.1-.5 2.4.4 2.2 1.6C15.8 13 12.1 16.2 7 17Z" />
                <path d="M9 13c1.8.1 3.4.8 4.8 2.1" />
              </svg>
            )}
            {category.icon === 'medical' && (
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M9.6 3h4.8v6.6H21v4.8h-6.6V21H9.6v-6.6H3V9.6h6.6V3Z" />
              </svg>
            )}
            {category.icon === 'community' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                <path d="M17 10a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
                <path d="M3.5 20a5.5 5.5 0 0 1 11 0" />
                <path d="M14.7 14.4A4.7 4.7 0 0 1 20.5 19" />
              </svg>
            )}
          </span>
          </a>
        ))}
      </div>
    </nav>

    {featuredPost && (
      <a href={`/blog/${featuredPost.slug}`} class="mobile-feature-card">
        {getPostImage(featuredPost) && (
          <div class="mobile-feature-image">
            <OptimizedImage
              image={getPostImage(featuredPost)}
              alt={featuredPost.title}
              class="w-full h-full object-cover"
              aspectRatio="aspect-square"
              loading="eager"
              mobileMaxSrcSetWidth={400}
              mobileTargetWidths={[160, 240, 320, 400]}
              targetWidths={[320, 400]}
              mobileSizes="38vw"
              quality={72}
            />
          </div>
        )}
        <div class="mobile-feature-copy">
          <span class="mobile-kicker">{getCategoryLabel(featuredPost.category)}</span>
          <h2>{featuredPost.title}</h2>
          <p>{featuredPost.description || 'Panduan ringkas Arkara untuk keputusan praktis saat kondisi tidak ideal.'}</p>
          <div>
            <span>◷</span>
            <span>6 menit baca</span>
            <span class="mobile-bookmark">⌑</span>
          </div>
        </div>
      </a>
    )}

    <section class="mobile-reading-section">
      <div class="mobile-section-head">
        <h2>Lanjutkan Membaca</h2>
        <a href="/blog">Lihat semua ›</a>
      </div>
      <div class="mobile-continue-list">
        {continuePosts.map((post, index) => (
          <a href={`/blog/${post.slug}`} class="mobile-continue-item">
            {getPostImage(post) && (
              <div class="mobile-continue-image">
                <OptimizedImage
                  image={getPostImage(post)}
                  alt={post.title}
                  class="w-full h-full object-cover"
                  aspectRatio="aspect-square"
                  loading="lazy"
                  mobileMaxSrcSetWidth={240}
                  mobileTargetWidths={[120, 160, 240]}
                  targetWidths={[160, 240]}
                  mobileSizes="72px"
                  quality={70}
                />
              </div>
            )}
            <div>
              <h3>{post.title}</h3>
              <span>{index === 0 ? '60%' : '30%'} selesai</span>
              <div class="mobile-progress"><i style={`width:${index === 0 ? 60 : 30}%`}></i></div>
            </div>
            <span class="mobile-small-bookmark">⌑</span>
          </a>
        ))}
      </div>
    </section>

    <section class="mobile-editor-section">
      <div class="mobile-section-head">
        <h2>Pilihan Editor</h2>
        <a href="/blog">Lihat semua ›</a>
      </div>
      <div class="mobile-editor-rail">
        {editorPosts.map((post, index) => (
          <a href={`/blog/${post.slug}`} class="mobile-editor-card">
            {getPostImage(post) && (
              <div>
                <OptimizedImage
                  image={getPostImage(post)}
                  alt={post.title}
                  class="w-full h-full object-cover"
                  aspectRatio="aspect-video"
                  loading="lazy"
                  mobileMaxSrcSetWidth={360}
                  mobileTargetWidths={[160, 240, 320, 360]}
                  targetWidths={[240, 360]}
                  mobileSizes="42vw"
                  quality={72}
                />
              </div>
            )}
            <span>{getCategoryLabel(post.category)}</span>
            <h3>{post.title}</h3>
          </a>
        ))}
      </div>
    </section>
  </section>

  <!-- ── HERO SECTION (GRID 2 COLUMNS) ─────────────────── -->
  <div class="home-hero-grid grid grid-cols-1 md:grid-cols-[1fr_400px] border-b-4 border-zinc-900 bg-zinc-900 overflow-hidden">
    <HeroCarousel posts={displayPosts} />
    <MascotSection 
      mascotImage={hero?.mascot_image} 
      speechText={hero?.mascot_speech_text} 
      tagline={hero?.mascot_tagline} 
    />
  </div>

  <!-- ── WARNING BAND TICKER ───────────────────────────── -->
  <div class="home-ticker" style="
    background: var(--yellow-manual);
    border-top: 3px solid var(--ink);
    border-bottom: 3px solid var(--ink);
    padding: 0.6rem 0;
    overflow: hidden;
    position: relative;
    z-index: 2;
  " aria-hidden="true">
    <div style="
      display: flex;
      gap: 3rem;
      animation: scroll-ticker 22s linear infinite;
      white-space: nowrap;
    ">
      {tickerDouble.map(item => (
        <span style="
          font-family: 'Barlow Condensed', sans-serif;
          font-weight: 700;
          font-size: 0.78rem;
          letter-spacing: 0.2em;
          color: var(--ink);
          text-transform: uppercase;
          display: inline-flex;
          align-items: center;
          gap: 1rem;
        ">
          <span style="color:var(--red-warning);font-size:0.5rem;">◆</span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ── RECENT ARTICLES ───────────────────────────────── -->
  <section class="home-feed-section" style="
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    position: relative;
    z-index: 2;
  ">
    <!-- Section header -->
    <div style="
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 2.5rem;
      gap: 1.5rem;
      flex-wrap: wrap;
    ">
      <div>
        <h1 style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0;">
          Arkara — Survive with Knowledge | Pengetahuan Survival Indonesia
        </h1>
        <div style="
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.6rem;
          letter-spacing: 0.25em;
          color: var(--warm-grey);
          text-transform: uppercase;
          display: flex; align-items: center; gap: 0.75rem;
          margin-bottom: 0.75rem;
        ">
          <span style="display:inline-block;width:20px;height:1px;background:var(--green-terminal);"></span>
          SECTION A — ARTIKEL TERBARU
        </div>
        <h2 style="
          font-family: 'Barlow Condensed', sans-serif;
          font-size: clamp(2rem, 4vw, 3rem);
          font-weight: 800;
          text-transform: uppercase;
          color: var(--ink);
          line-height: 1;
          margin: 0;
        ">JURNAL<br><span style="font-family:'Special Elite',cursive;text-transform:none;font-size:0.75em;color:var(--green-muted);">Teranyar</span></h2>
      </div>

      <a href="/blog" style="
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.7rem 1.4rem;
        background: transparent;
        color: var(--ink);
        border: 2px solid var(--ink);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.15s;
        white-space: nowrap;
      "
      onmouseover="this.style.background='var(--ink)';this.style.color='var(--cream)';this.style.transform='translate(-2px,-2px)';this.style.boxShadow='4px 4px 0 var(--ink)'"
      onmouseout="this.style.background='transparent';this.style.color='var(--ink)';this.style.transform='';this.style.boxShadow=''"
      >LIHAT SEMUA →</a>
    </div>

    <!-- Posts grid -->
    {recentPosts.length > 0 ? (
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; background: var(--ink); border: 3px solid var(--ink);" class="posts-grid home-feed-grid">
        {displayPosts.map((post) => (
          <div style="background: var(--cream);">
            <PostCard
              title={post.title}
              excerpt={post.description || ''}
              category={post.category}
              date={post.published_at || ''}
              slug={post.slug}
              readingTime={post.reading_time}
              image={post.thumbnail_image || post.cover_image}
              sizes="(max-width: 640px) 100vw, (max-width: 900px) 50vw, 400px"
            />
          </div>
        ))}
      </div>
    ) : (
      <div style="
        background: var(--paper);
        border: 3px solid var(--ink);
        padding: 5rem 2rem;
        text-align: center;
      ">
        <p style="font-family:'Special Elite',cursive;font-size:1.2rem;color:var(--warm-grey);">Belum ada jurnal yang diterbitkan.</p>
      </div>
    )}
  </section>

  <!-- ── PILAR PENGETAHUAN ──────────────────────────────── -->
  <section class="home-category-section" style="
    background: var(--ink);
    border-top: 3px solid var(--green-terminal);
    border-bottom: 3px solid var(--green-terminal);
    padding: 4rem 2rem;
    position: relative;
    overflow: hidden;
    z-index: 2;
  ">
    <!-- Watermark text -->
    <div style="
      position: absolute; bottom: -1rem; right: 1rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 8rem;
      color: rgba(143,175,143,0.04);
      letter-spacing: -0.03em;
      pointer-events: none;
      line-height: 1;
    " aria-hidden="true">MODUL</div>

    <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">

      <!-- Section header -->
      <div style="margin-bottom: 2.5rem;">
        <div style="
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.6rem;
          letter-spacing: 0.25em;
          color: var(--green-terminal);
          text-transform: uppercase;
          display: flex; align-items: center; gap: 0.75rem;
          margin-bottom: 0.75rem;
        ">
          <span style="display:inline-block;width:20px;height:1px;background:var(--green-terminal);"></span>
          SECTION B — TOPIK UTAMA
        </div>
        <h2 style="
          font-family: 'Barlow Condensed', sans-serif;
          font-size: clamp(2rem, 4vw, 3rem);
          font-weight: 800;
          text-transform: uppercase;
          color: var(--cream);
          line-height: 1;
          margin: 0;
        ">PILAR<br>PENGETAHUAN</h2>
      </div>

      <!-- Category grid — flat ink-border panels -->
      <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 1.5px; background: var(--green-terminal); border: 2px solid var(--green-terminal);" class="cat-grid home-category-grid">
        {categories.map((cat) => (
          <a href={`/panduan?category=${cat.slug}`} style="
            background: var(--ink);
            padding: 1.5rem 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            transition: background 0.15s;
            border: none;
          "
          onmouseover="this.style.background='var(--green-dark)'"
          onmouseout="this.style.background='var(--ink)'"
          >
            <span style="font-size: 2rem; filter: saturate(0.7);">{cat.icon}</span>
            <span style="
              font-family: 'Barlow Condensed', sans-serif;
              font-size: 0.85rem;
              font-weight: 700;
              text-transform: uppercase;
              letter-spacing: 0.05em;
              color: var(--green-terminal);
              text-align: center;
            ">{cat.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA / PANDUAN ─────────────────────────────────── -->
  <section class="home-cta-section" style="
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    position: relative;
    z-index: 2;
  ">
    <div style="
      background: var(--ink);
      border: 3px solid var(--green-terminal);
      box-shadow: 8px 8px 0 var(--green-terminal);
      padding: 3.5rem;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: center;
      position: relative;
      overflow: hidden;
    " class="cta-grid">
      <!-- Background watermark -->
      <div style="
        position:absolute;right:-1rem;bottom:-1rem;
        font-family:'Barlow Condensed',sans-serif;
        font-size:10rem;
        font-weight:800;
        color:rgba(143,175,143,0.04);
        line-height:1;
        pointer-events:none;
        letter-spacing:-0.04em;
      " aria-hidden="true">PANDUAN</div>

      <div style="position:relative;z-index:1;">
        <div style="
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.58rem;
          letter-spacing: 0.2em;
          color: var(--green-terminal);
          text-transform: uppercase;
          margin-bottom: 0.75rem;
          display: flex; align-items: center; gap: 0.5rem;
        ">
          <span style="display:inline-block;width:16px;height:1px;background:var(--green-terminal);"></span>
          AKSES OFFLINE AVAILABLE SOON
        </div>
        <h2 style="
          font-family: 'Barlow Condensed', sans-serif;
          font-size: clamp(1.8rem, 4vw, 3rem);
          font-weight: 800;
          text-transform: uppercase;
          color: var(--cream);
          line-height: 0.95;
          margin-bottom: 1rem;
        ">
          {cta?.headline || 'KOLEKSI'}
          <br>
          <span style="font-family:'Special Elite',cursive;text-transform:none;color:var(--yellow-manual);">
            {cta?.body_text ? 'Panduan Taktis' : 'Panduan Taktis'} 
          </span>
        </h2>
        <p style="
          font-size: 0.85rem;
          color: var(--warm-grey);
          max-width: 400px;
          line-height: 1.65;
        ">
          {cta?.body_text || 'Instruksi teknis yang terhubung dengan Buku Pegangan Krisis. Dapat dibaca offline, dirancang untuk situasi darurat.'}
        </p>
      </div>

      <div style="position:relative;z-index:1;flex-shrink:0;">
        <a href={cta?.button_href || '/panduan'} style="
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.72rem;
          letter-spacing: 0.15em;
          text-transform: uppercase;
          padding: 1rem 2rem;
          background: var(--green-terminal);
          color: var(--ink);
          border: 2px solid var(--green-terminal);
          text-decoration: none;
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          font-weight: 700;
          white-space: nowrap;
          transition: all 0.15s;
        "
        onmouseover="this.style.background='var(--yellow-manual)';this.style.borderColor='var(--yellow-manual)';this.style.transform='translate(-2px,-2px)';this.style.boxShadow='4px 4px 0 var(--green-terminal)'"
        onmouseout="this.style.background='var(--green-terminal)';this.style.borderColor='var(--green-terminal)';this.style.transform='';this.style.boxShadow=''"
        >▶ {cta?.button_label || 'MULAI PELAJARI'}</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .mobile-home-appbar,
  .mobile-topic-rail,
  .mobile-home-screen {
    display: none;
  }

  @media (max-width: 900px) {
    .posts-grid { grid-template-columns: 1fr !important; }
    .cat-grid   { grid-template-columns: repeat(3, 1fr) !important; }
    .cta-grid   { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 768px) {
    :global(html),
    :global(body),
    :global(main) {
      background: #070b0c !important;
    }

    :global(main) {
      padding-bottom: 0 !important;
    }

    .mobile-home-appbar,
    .mobile-topic-rail {
      display: none !important;
    }

    .mobile-home-screen {
      display: block;
      min-height: 100dvh;
      padding: 0.75rem 0.9rem calc(5.1rem + env(safe-area-inset-bottom));
      background:
        radial-gradient(circle at 50% -10%, rgba(110,231,183,0.08), transparent 32rem),
        #070b0c;
      color: #f8fafc;
    }

    .mobile-home-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding-top: 0.2rem;
      margin-bottom: 1.25rem;
    }

    .mobile-brand {
      color: #f3ead9;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 1.55rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      text-decoration: none;
    }

    .mobile-header-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .mobile-header-actions a {
      color: #f8fafc;
      display: grid;
      height: 1.7rem;
      width: 1.7rem;
      place-items: center;
      text-decoration: none;
    }

    .mobile-header-actions svg {
      height: 1.45rem;
      width: 1.45rem;
    }

    .mobile-home-tabs {
      position: relative;
      display: grid;
