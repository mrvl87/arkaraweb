---
/**
 * Homepage
 * Displays hero, recent articles, categories, and CTA
 */

import { getRecentPosts } from '../lib/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import PostCard from '../components/blog/PostCard.astro';

const recentPosts = await getRecentPosts(3);

const categoryLabels: Record<string, string> = {
  air: 'Air',
  energi: 'Energi',
  pangan: 'Pangan',
  medis: 'Medis',
  keamanan: 'Keamanan',
  komunitas: 'Komunitas',
};

const categories = [
  { name: 'Air', slug: 'air', icon: '💧' },
  { name: 'Energi', slug: 'energi', icon: '⚡' },
  { name: 'Pangan', slug: 'pangan', icon: '🌾' },
  { name: 'Medis', slug: 'medis', icon: '⚕️' },
  { name: 'Keamanan', slug: 'keamanan', icon: '🛡️' },
  { name: 'Komunitas', slug: 'komunitas', icon: '👥' },
];
---

<BaseLayout title="Beranda">
  <!-- Hero Section -->
  <section class="bg-forest text-sand pt-32 pb-48 px-6 relative overflow-hidden">
    <!-- Decorative elements -->
    <div class="absolute inset-0 opacity-10 pointer-events-none bg-[radial-gradient(#E6D8B5_1.5px,transparent_1.5px)] [background-size:32px_32px]"></div>
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-amber-600/20 blur-[120px]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-moss/20 blur-[120px]"></div>

    <div class="max-w-5xl mx-auto text-center relative z-10">
      <div class="inline-block mb-6 px-4 py-1.5 border border-amber-500/30 rounded-full bg-amber-500/5 backdrop-blur-sm">
         <span class="text-[10px] font-black uppercase tracking-[0.3em] text-amber-500">Platform Pengetahuan Survival Indonesia</span>
      </div>
      <h1 class="font-display text-7xl md:text-9xl font-black mb-8 tracking-tight leading-[0.9]">
        Arkara
      </h1>
      <p class="text-2xl md:text-4xl font-light mb-12 text-sand/60 font-display italic max-w-3xl mx-auto leading-relaxed">
        "<span class="text-sand">Survive with Knowledge</span>. Membangun kemandirian melalui strategi dan taktik praktis."
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a href="/blog" class="w-full sm:w-auto px-10 py-5 bg-amber-600 text-white rounded-2xl font-black uppercase tracking-[0.2em] text-xs hover:bg-white hover:text-forest transition-all transform hover:-translate-y-1 shadow-2xl shadow-amber-600/20 active:scale-95">
           Eksplor Jurnal
        </a>
        <a href="/panduan" class="w-full sm:w-auto px-10 py-5 border-2 border-sand/20 text-sand rounded-2xl font-black uppercase tracking-[0.2em] text-xs hover:bg-sand/10 transition-all transform hover:-translate-y-1 active:scale-95">
           Panduan Teknis
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Articles Grid -->
  <section class="max-w-7xl mx-auto px-6 -mt-24 pb-32 relative z-20">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-xl">
        <div class="h-1.5 w-20 bg-amber-600 rounded-full mb-6"></div>
        <h2 class="font-display text-5xl font-black text-forest mb-4 leading-tight">
          Jurnal <span class="text-amber-600 font-light italic">Teranyar</span>
        </h2>
        <p class="text-stone/60 text-lg font-light leading-relaxed">Wawasan strategis dan teknik lapangan terbaru yang dirancang untuk kesiapan Anda menghadapi segala situasi.</p>
      </div>
      <a href="/blog" class="px-8 py-4 bg-white border border-stone/10 rounded-xl text-forest hover:bg-forest hover:text-sand font-black uppercase tracking-widest text-[10px] transition-all shadow-xl shadow-forest/5 flex items-center gap-3 group">
        Lihat Semua Jurnal
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    {recentPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
        {recentPosts.map((post) => (
          <PostCard
            title={post.title}
            excerpt={post.description || ''}
            category={categoryLabels[post.category] || post.category}
            date={post.published_at || ''}
            slug={post.slug}
            content={post.content || ''}
            image={post.thumbnail_image || post.cover_image}
          />
        ))}
      </div>
    ) : (
      <div class="bg-white border-2 border-dashed border-stone/10 rounded-3xl p-32 text-center">
        <div class="text-6xl mb-6 opacity-20">📜</div>
        <p class="text-stone/40 font-display text-xl italic font-light">Belum ada jurnal yang diterbitkan.</p>
      </div>
    )}
  </section>

  <!-- Categories Section -->
  <section class="bg-stone/5 py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 max-w-2xl mx-auto">
        <h2 class="font-display text-5xl font-black text-forest mb-6">Pilar Pengetahuan</h2>
        <p class="text-stone/60 text-lg font-light leading-relaxed">
          Kuasai dasar-dasar kemandirian melalui pilar eksplorasi kami yang mendalam dan terstruktur.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-6 gap-6 md:gap-8">
        {categories.map((cat) => (
          <a href={`/blog?category=${cat.slug}`} class="block group">
            <div class="bg-white border border-stone/5 rounded-3xl p-10 flex flex-col items-center justify-center h-full hover:shadow-2xl hover:shadow-forest/5 hover:-translate-y-2 transition-all duration-500 group-hover:border-amber-600/30">
               <div class="text-6xl mb-8 transform group-hover:scale-125 transition-transform duration-500 drop-shadow-lg">{cat.icon}</div>
               <h3 class="font-display text-xl font-black text-forest group-hover:text-amber-600 transition-colors uppercase tracking-wider">{cat.name}</h3>
               <div class="mt-4 w-0 group-hover:w-8 h-1 bg-amber-600 rounded-full transition-all duration-500"></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Premium CTA Section -->
  <section class="max-w-7xl mx-auto px-6 py-32">
     <div class="bg-forest rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden shadow-2xl shadow-forest/30">
        <!-- Background Geometry -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-amber-600/10 rounded-full -translate-y-1/2 translate-x-1/2 blur-[100px]"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-moss/10 rounded-full translate-y-1/2 -translate-x-1/2 blur-[100px]"></div>
        
        <div class="relative z-10 max-w-3xl mx-auto">
           <h2 class="font-display text-5xl md:text-7xl font-black text-sand mb-8 leading-tight">
              Akses Koleksi <br/><span class="text-amber-500 italic">Panduan Taktis</span>
           </h2>
           <p class="text-sand/60 text-xl md:text-2xl font-light mb-12 leading-relaxed">
              Dapat dibaca secara offline dan didesain untuk situasi darurat. Pastikan Anda memiliki salinan pengetahuan sebelum krisis menyapa.
           </p>
           <a
             href="/panduan"
             class="inline-flex items-center gap-4 bg-amber-600 text-white px-12 py-6 rounded-2xl font-black uppercase tracking-[0.2em] text-sm hover:bg-white hover:text-forest transition-all transform hover:-translate-y-1 shadow-2xl active:scale-95"
           >
             Mulai Pelajari
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
           </a>
        </div>
     </div>
  </section>
</BaseLayout>
