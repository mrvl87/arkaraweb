---
/**
 * PostLayout.astro â€” Retro Survival Manual 2.0
 * Props: unchanged (backward compatible with blog/[slug] and panduan/[slug])
 * Changes:
 *   - Removed rounded-3xl/shadow-2xl/gradient-br modern aesthetics
 *   - Header: dark ink bg + muted gradient, mono section label
 *   - Content area: paper bg, ink border + shadow (card-ink style)
 *   - Sidebar: dark panel, terminal feel
 *   - TOC: mono font, ink borders
 */
import BaseLayout from './BaseLayout.astro';
import OptimizedImage from '../components/ui/OptimizedImage.astro';
import ReadingMeta from '../components/blog/ReadingMeta.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import RelatedPosts from '../components/blog/RelatedPosts.astro';
import { calculateReadingTime } from '../lib/markdown';

interface Props {
  title: string;
  description?: string;
  publishDate?: string;
  category?: string;
  coverImage?: any;
  headings?: any[];
  content?: string;
  currentSlug?: string;
  canonicalHref?: string;
  contentType?: 'blog' | 'panduan';
  quickAnswer?: string | null;
  keyTakeaways?: string[];
  faq?: Array<{ question: string; answer: string }>;
  editorialFormat?: 'legacy' | 'mobile_reader' | 'technical_guide';
}

const {
  title,
  description,
  publishDate,
  category,
  coverImage,
  headings = [],
  content = '',
  currentSlug,
  canonicalHref,
  contentType,
  quickAnswer,
  keyTakeaways = [],
  faq = [],
  editorialFormat = 'legacy',
} = Astro.props;
const readingTime = calculateReadingTime(content);
const cleanQuickAnswer = quickAnswer?.trim();
const cleanTakeaways = keyTakeaways.map((item) => item?.trim()).filter(Boolean);
const cleanFaq = faq
  .map((item) => ({
    question: item.question?.trim(),
    answer: item.answer?.trim(),
  }))
  .filter((item) => item.question && item.answer);
const isMobileReader = editorialFormat === 'mobile_reader';
const isTechnicalGuide = editorialFormat === 'technical_guide';
const hasReaderMode = isMobileReader || isTechnicalGuide;
const hasMobileStructure = hasReaderMode && Boolean(cleanQuickAnswer || cleanTakeaways.length || cleanFaq.length || headings.length);
const readerLabel = isTechnicalGuide ? 'Prosedur Cepat' : 'Jawaban Singkat';
const takeawayLabel = isTechnicalGuide ? 'Checklist Lapangan' : 'Inti Artikel';
const tocLabel = isTechnicalGuide ? 'Urutan Prosedur' : 'Isi Artikel';
const faqLabel = isTechnicalGuide ? 'Pertanyaan Operasional' : 'FAQ';

function resolveSocialImage(image: any): string | undefined {
  if (!image) return undefined;
  if (typeof image === 'string') return image;

  return image.formats?.lg
    || image.formats?.original
    || image.formats?.md
    || image.url
    || image.src
    || undefined;
}

const ogImageUrl = resolveSocialImage(coverImage);
const ogImageAlt = typeof coverImage === 'string'
  ? title
  : coverImage?.alt_text || title;

---

<BaseLayout
  title={title}
  description={description}
  image={ogImageUrl}
  imageAlt={ogImageAlt}
  canonicalHref={canonicalHref}
  type="article"
>

  <!-- â”€â”€ POST HEADER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
  <header class="post-hero" style="
    background: var(--ink);
    border-bottom: 3px solid var(--green-terminal);
    padding: 4rem 2rem 5rem;
    position: relative;
    overflow: hidden;
  ">
    <!-- Subtle grid overlay on header -->
    <div style="
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(143,175,143,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(143,175,143,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    " aria-hidden="true"></div>

    <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">

      <!-- Section label -->
      <div class="post-meta-strip" style="
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.25em;
        color: var(--green-terminal);
        text-transform: uppercase;
        display: flex; align-items: center; gap: 0.75rem;
        margin-bottom: 1.5rem;
      ">
        <span style="display:inline-block;width:20px;height:1px;background:var(--green-terminal);"></span>
        {category ? `KATEGORI: ${category.toUpperCase()}` : 'ARTIKEL'}
        {publishDate && (
          <span style="color: var(--warm-grey);">
            â€” {new Date(publishDate).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' })}
          </span>
        )}
        {readingTime > 0 && (
          <span style="color: var(--warm-grey);">â€” {readingTime} MIN</span>
        )}
      </div>

      <!-- Title -->
      <h1 class="post-title" style="
        font-family: 'Barlow Condensed', sans-serif;
        font-size: clamp(2.2rem, 6vw, 5rem);
        font-weight: 800;
        text-transform: uppercase;
        color: var(--cream);
        line-height: 0.95;
        letter-spacing: -0.01em;
        max-width: 800px;
        margin-bottom: 1.25rem;
      ">{title}</h1>

      {description && (
        <p class="post-description" style="
          font-family: 'Barlow', sans-serif;
          font-size: 1rem;
          color: var(--warm-grey);
          max-width: 560px;
          line-height: 1.65;
          border-left: 3px solid var(--green-terminal);
          padding-left: 1rem;
        ">{description}</p>
      )}
    </div>
  </header>

  <!-- â”€â”€ ARTICLE BODY â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
  <div class="post-shell" style="max-width: 1200px; margin: 0 auto; padding: 0 2rem 5rem; margin-top: -2rem; position: relative; z-index: 10;">
    <div style="display: grid; grid-template-columns: 1fr 300px; gap: 2rem; align-items: start;" class="post-grid">

      <!-- Content column -->
      <article class={`post-article ${hasMobileStructure ? 'has-mobile-reader' : ''} ${isTechnicalGuide ? 'is-technical-guide' : ''}`} style="
        background: var(--paper);
        border: 3px solid var(--ink);
        box-shadow: 6px 6px 0 var(--ink);
      ">
        {coverImage && (
          <div style="border-bottom: 3px solid var(--ink); overflow: hidden;">
            <OptimizedImage
              image={coverImage}
              alt={title}
              class="w-full object-cover"
              style="filter: saturate(0.7) contrast(1.05); display: block;"
              aspectRatio="aspect-video"
              loading="eager"
              fetchpriority="high"
              sizes="(max-width: 1200px) 100vw, 1200px"
              mobileMaxSrcSetWidth={800}
              mobileTargetWidths={[400, 640, 800]}
              targetWidths={[800, 1200]}
              mobileSizes="100vw"
              quality={74}
            />
          </div>
        )}

        <div style="padding: 2.5rem 3rem;" class="post-body-padding">
          {hasMobileStructure && (
            <section class={`mobile-reader-stack ${isTechnicalGuide ? 'technical-guide-stack' : ''}`} aria-label={isTechnicalGuide ? 'Struktur technical guide' : 'Ringkasan mobile reader'}>
              {cleanQuickAnswer && (
                <div class="mobile-reader-answer">
                  <p class="mobile-reader-eyebrow">{readerLabel}</p>
                  <p>{cleanQuickAnswer}</p>
                </div>
              )}

              {cleanTakeaways.length > 0 && (
                <div class="mobile-reader-takeaways">
                  <div class="mobile-reader-section-title">{takeawayLabel}</div>
                  <ol>
                    {cleanTakeaways.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ol>
                </div>
              )}

              {headings.length > 0 && (
                <details class="mobile-reader-toc">
                  <summary>
                    <span class="mobile-reader-toc-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M8 6h12M8 12h12M8 18h12" />
                        <path d="M4 6h.01M4 12h.01M4 18h.01" />
                      </svg>
                    </span>
                    <span>{tocLabel}</span>
                  </summary>
                  <nav>
                    {headings.map((heading: any) => (
                      <a
                        href={`#${heading.slug || heading.id}`}
                        data-mobile-toc-link
                        data-heading-text={heading.text}
                      >
                        {heading.text}
                      </a>
                    ))}
                  </nav>
                </details>
              )}
            </section>
          )}

          <div class="prose-arkara">
            <slot />
          </div>

          {hasReaderMode && cleanFaq.length > 0 && (
            <section class="mobile-reader-faq" aria-label="FAQ">
              <div class="mobile-reader-section-title">{faqLabel}</div>
              {cleanFaq.map((item) => (
                <details>
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </section>
          )}

          <!-- Article footer -->
          <div style="
            margin-top: 3rem;
            padding-top: 1.5rem;
            border-top: 3px solid var(--cream-dark);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
          ">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <div style="
                width: 36px; height: 36px;
                background: var(--ink);
                border: 2px solid var(--green-terminal);
                display: flex; align-items: center; justify-content: center;
                font-family: 'Share Tech Mono', monospace;
                font-size: 0.65rem;
                color: var(--green-terminal);
                font-weight: bold;
              ">AR</div>
              <div>
                <p style="font-family:'Share Tech Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;color:var(--warm-grey);text-transform:uppercase;">Ditulis oleh</p>
                <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:0.85rem;text-transform:uppercase;color:var(--ink);">Tim Redaksi Arkara</p>
              </div>
            </div>
            <a href={`/${contentType || 'blog'}`} style="
              font-family: 'Share Tech Mono', monospace;
              font-size: 0.62rem;
              letter-spacing: 0.15em;
              color: var(--green-terminal);
              text-decoration: none;
              text-transform: uppercase;
              border: 1px solid var(--green-terminal);
              padding: 0.4rem 0.8rem;
              transition: background 0.15s;
            "
            onmouseover="this.style.background='var(--green-dark)'"
            onmouseout="this.style.background=''"
            >â† KEMBALI KE {contentType === 'panduan' ? 'PANDUAN' : 'BLOG'}</a>
          </div>

          <!-- Related Posts Section -->
          {currentSlug && contentType && (
            <RelatedPosts currentSlug={currentSlug} category={category} contentType={contentType} />
          )}
        </div>
      </article>

      <!-- Sidebar -->
      <aside style="position: sticky; top: 72px; display: flex; flex-direction: column; gap: 1.5rem;" class="post-sidebar">

        <!-- Table of Contents -->
        <TableOfContents headings={headings} />

        <!-- Guide Buddy sidebar widget -->
        <div style="
          background: var(--ink);
          border: 3px solid var(--green-terminal);
          padding: 1.5rem;
          position: relative;
          overflow: hidden;
        ">
          <div style="
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.58rem;
            letter-spacing: 0.2em;
            color: var(--green-terminal);
            text-transform: uppercase;
            margin-bottom: 1rem;
            display: flex; align-items: center; gap: 0.5rem;
          ">
            <span style="display:inline-block;width:8px;height:8px;background:var(--green-terminal);border-radius:50%;animation:pulse-dot 2s infinite;"></span>
            GUIDE BUDDY
          </div>

          <!-- Mini mascot thumbsup -->
          <div style="text-align: center; margin-bottom: 1rem;">
            <svg width="80" height="95" viewBox="0 0 120 140" aria-hidden="true">
              <rect x="36" y="72" width="48" height="55" rx="6" fill="#3D5C3D" stroke="#8FAF8F" stroke-width="2"/>
              <ellipse cx="60" cy="45" rx="28" ry="30" fill="#D8C58A" stroke="#8FAF8F" stroke-width="2.5"/>
              <path d="M32 38 Q36 18 60 16 Q84 18 88 38" fill="#2A2218"/>
              <circle cx="50" cy="42" r="4" fill="#2A2218"/>
              <circle cx="70" cy="42" r="4" fill="#2A2218"/>
              <circle cx="51.5" cy="40.5" r="1.5" fill="white"/>
              <circle cx="71.5" cy="40.5" r="1.5" fill="white"/>
              <path d="M50 55 Q60 62 70 55" stroke="#2A2218" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <rect x="10" y="62" width="14" height="30" rx="7" fill="#D8C58A" stroke="#8FAF8F" stroke-width="2" transform="rotate(-15 17 77)"/>
              <ellipse cx="8" cy="56" rx="8" ry="10" fill="#D8C58A" stroke="#8FAF8F" stroke-width="2" transform="rotate(-20 8 56)"/>
              <rect x="96" y="62" width="14" height="30" rx="7" fill="#D8C58A" stroke="#8FAF8F" stroke-width="2" transform="rotate(10 103 77)"/>
              <rect x="40" y="114" width="14" height="20" rx="5" fill="#2A2218" stroke="#8FAF8F" stroke-width="1.5"/>
              <rect x="66" y="114" width="14" height="20" rx="5" fill="#2A2218" stroke="#8FAF8F" stroke-width="1.5"/>
            </svg>
          </div>

          <div style="
            background: rgba(143,175,143,0.08);
            border: 1px solid rgba(143,175,143,0.2);
            padding: 1rem;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.68rem;
            line-height: 1.7;
            color: var(--cream-dark);
          ">
            Siap menghadapi segala situasi? Panduan ini bisa kamu praktekkan langsung. Simpan halaman ini untuk referensi offline!
          </div>
        </div>

      </aside>

    </div>
  </div>

  <style>
    @media (max-width: 900px) {
      :global(html),
      :global(body),
      :global(main) {
        background: #070b0c !important;
      }

      :global(main) {
        padding-bottom: 0 !important;
      }

      .post-hero {
        background: #070b0c !important;
        border-bottom: 1px solid rgba(255,255,255,0.08) !important;
        padding: 1.25rem 1rem 1rem !important;
      }

      .post-meta-strip {
        margin-bottom: 1rem !important;
        gap: 0.5rem !important;
        flex-wrap: wrap !important;
        color: #6ee7b7 !important;
      }

      .post-title {
        font-family: 'Barlow', sans-serif !important;
        font-size: clamp(1.68rem, 7.7vw, 2.42rem) !important;
        line-height: 1.08 !important;
        text-transform: none !important;
        color: #f8fafc !important;
        letter-spacing: 0 !important;
        margin-bottom: 0 !important;
      }

      .post-description {
        display: none !important;
      }

      .post-shell {
        margin-top: 0 !important;
        padding: 0 0 calc(5.1rem + env(safe-area-inset-bottom)) !important;
        max-width: none !important;
        background: #070b0c !important;
      }

      .post-grid { grid-template-columns: 1fr !important; gap: 0 !important; }
      .post-sidebar { display: none !important; }
      .post-article {
        background: #070b0c !important;
        border: 0 !important;
        box-shadow: none !important;
      }

      .post-article > div:first-child {
        border-bottom: 0 !important;
        border-radius: 0 0 24px 24px;
      }

      .post-body-padding { padding: 1rem !important; }

      .mobile-reader-stack {
        display: grid !important;
      }

      .prose-arkara {
        color: #cbd5e1 !important;
        font-size: 1rem !important;
        line-height: 1.78 !important;
      }

      .prose-arkara :global(h1),
      .prose-arkara :global(h2),
      .prose-arkara :global(h3) {
        color: #f8fafc !important;
        font-family: 'Barlow', sans-serif !important;
        text-transform: none !important;
        letter-spacing: 0 !important;
        border-bottom: 0 !important;
      }

      .prose-arkara :global(h2) {
        margin-top: 2rem !important;
        font-size: 1.35rem !important;
      }

      .prose-arkara :global(h3) {
        font-size: 1.1rem !important;
      }

      .prose-arkara :global(h2[id]),
      .prose-arkara :global(h3[id]) {
        scroll-margin-top: 1.25rem;
      }

      .prose-arkara :global(p),
      .prose-arkara :global(li) {
        color: #cbd5e1 !important;
      }

      .prose-arkara :global(strong),
      .prose-arkara :global(b) {
        color: #f8fafc !important;
        font-weight: 800 !important;
      }

      .prose-arkara :global(ul li::before) {
        content: "" !important;
        top: 0.72rem !important;
        width: 0.38rem !important;
        height: 0.38rem !important;
        border-radius: 999px !important;
        background: #6ee7b7 !important;
      }

      .prose-arkara :global(a) {
        color: #6ee7b7 !important;
      }

      .prose-arkara :global(blockquote) {
        background: rgba(110,231,183,0.08) !important;
        border-left: 3px solid #6ee7b7 !important;
        color: #d1fae5 !important;
      }

      .mobile-reader-faq {
        display: grid !important;
      }
    }

    .mobile-reader-stack {
      display: none;
      gap: 1rem;
      margin-bottom: 1.75rem;
    }

    .mobile-reader-answer,
    .mobile-reader-takeaways,
    .mobile-reader-toc,
    .mobile-reader-faq details {
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 20px;
      background: rgba(255,255,255,0.045);
    }

    .mobile-reader-answer {
      padding: 1rem;
      background: rgba(110,231,183,0.1);
      border-color: rgba(110,231,183,0.24);
    }

    .is-technical-guide .mobile-reader-answer {
      background: rgba(245,158,11,0.1);
      border-color: rgba(245,158,11,0.28);
    }

    .mobile-reader-answer p:last-child {
      margin: 0.35rem 0 0;
      color: #ecfdf5;
      font-size: 0.98rem;
      line-height: 1.65;
    }

    .mobile-reader-eyebrow,
    .mobile-reader-section-title {
      margin: 0;
      color: #6ee7b7;
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .is-technical-guide .mobile-reader-eyebrow,
    .is-technical-guide .mobile-reader-section-title {
      color: #fbbf24;
    }

    .mobile-reader-takeaways {
      padding: 1rem;
    }

    .mobile-reader-takeaways ol {
      display: grid;
      gap: 0.75rem;
      margin: 0.9rem 0 0;
      padding: 0;
      list-style: none;
      counter-reset: takeaway;
    }

    .mobile-reader-takeaways li {
      counter-increment: takeaway;
      display: grid;
      grid-template-columns: 1.8rem 1fr;
      gap: 0.75rem;
      color: #e2e8f0;
      line-height: 1.55;
    }

    .mobile-reader-takeaways li::before {
      content: counter(takeaway);
      width: 1.8rem;
      height: 1.8rem;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: rgba(110,231,183,0.12);
      color: #a7f3d0;
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.72rem;
      font-weight: 700;
    }

    .is-technical-guide .mobile-reader-takeaways li::before {
      border-radius: 7px;
      background: rgba(245,158,11,0.14);
      color: #fde68a;
      content: "✓";
    }

    .is-technical-guide .mobile-reader-takeaways,
    .is-technical-guide .mobile-reader-toc,
    .is-technical-guide .mobile-reader-faq details {
      border-color: rgba(245,158,11,0.18);
      background: rgba(255,255,255,0.035);
    }

    .mobile-reader-toc {
      padding: 0.9rem 1rem;
    }

    .mobile-reader-toc summary {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      list-style: none;
      cursor: pointer;
      color: #f8fafc;
      font-weight: 800;
    }

    .mobile-reader-toc summary::marker {
      content: "";
    }

    .mobile-reader-toc summary::-webkit-details-marker {
      display: none;
    }

    .mobile-reader-toc-icon {
      display: grid;
      width: 1.75rem;
      height: 1.75rem;
      place-items: center;
      border-radius: 999px;
      background: rgba(110,231,183,0.12);
      color: #6ee7b7;
      flex: 0 0 auto;
    }

    .mobile-reader-toc-icon svg {
      width: 1rem;
      height: 1rem;
    }

    .mobile-reader-toc nav {
      display: grid;
      gap: 0.65rem;
      margin-top: 0.9rem;
    }

    .mobile-reader-toc a {
      color: #94a3b8;
      text-decoration: none;
      font-size: 0.9rem;
      line-height: 1.35;
    }

    .prose-arkara :global(h2[id]),
    .prose-arkara :global(h3[id]) {
      scroll-margin-top: 6.5rem;
    }

    @media (max-width: 900px) {
      .prose-arkara :global(h2[id]),
      .prose-arkara :global(h3[id]) {
        scroll-margin-top: 1.25rem;
      }
    }

    .mobile-reader-faq {
      display: none;
      gap: 0.75rem;
      margin-top: 2rem;
    }

    .mobile-reader-faq details {
      padding: 1rem;
    }

    .mobile-reader-faq summary {
      cursor: pointer;
      color: #f8fafc;
      font-weight: 800;
      line-height: 1.35;
    }

    .mobile-reader-faq p {
      margin: 0.75rem 0 0;
      color: #94a3b8;
      line-height: 1.65;
    }
  </style>

  <script>
    const mobileTocLinks = document.querySelectorAll('[data-mobile-toc-link]');

    function normalizeMobileHeadingText(text) {
      return text
        .replace(/\s+/g, ' ')
        .trim()
        .toLowerCase();
    }

    function findMobileHeadingByText(text) {
      const normalizedText = normalizeMobileHeadingText(text);
      if (!normalizedText) {
        return null;
      }

      const headings = document.querySelectorAll('.prose-arkara h2, .prose-arkara h3');

      for (const heading of headings) {
        if (normalizeMobileHeadingText(heading.textContent || '') === normalizedText) {
          return heading;
        }
      }

      return null;
    }

    for (const link of mobileTocLinks) {
      link.addEventListener('click', (event) => {
        if (!(link instanceof HTMLAnchorElement) || !link.hash) {
          return;
        }

        const targetId = decodeURIComponent(link.hash.slice(1));
        let target = document.getElementById(targetId);

        if (!target) {
          const headingText = link.getAttribute('data-heading-text') || '';
          target = findMobileHeadingByText(headingText);

          if (target && targetId) {
            target.id = targetId;
          }
        }

        if (!target) {
          return;
        }

        event.preventDefault();

        const stickyOffset = window.matchMedia('(max-width: 900px)').matches ? 20 : 96;
        const targetTop = target.getBoundingClientRect().top + window.scrollY - stickyOffset;
        window.history.pushState(null, '', link.hash);
        window.scrollTo({
          top: Math.max(0, targetTop),
          behavior: 'smooth',
        });
      });
    }
  </script>

</BaseLayout>

