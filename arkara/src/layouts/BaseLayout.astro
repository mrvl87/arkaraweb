---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = 'Platform pengetahuan survival Indonesia. Pelajari teknik survival praktis untuk menghadapi krisis.',
  image = '/images/og-default.webp' 
} = Astro.props;

const siteName = 'Arkara';
const siteTitle = title ? `${title} — ${siteName}` : `${siteName} — Survive with Knowledge`;
const siteUrl = 'https://arkara.id'; // Adjust based on deployment
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteUrl)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, siteUrl)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  </head>
  <body class="bg-parchment text-stone selection:bg-amber selection:text-forest">
    <!-- Navigation -->
    <nav class="bg-forest text-sand py-6 px-6 sticky top-0 z-50 shadow-lg">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <div class="text-3xl font-display font-black tracking-tighter">
          <a href="/" class="hover:text-amber transition-colors">Arkara</a>
        </div>
        <ul class="hidden md:flex gap-10 text-sm font-bold uppercase tracking-widest">
          <li><a href="/blog" class="hover:text-amber transition-colors">Blog</a></li>
          <li><a href="/panduan" class="hover:text-amber transition-colors">Panduan</a></li>
          <li class="opacity-50 cursor-not-allowed"><span>CMS (Keystatic)</span></li>
        </ul>
        
        <!-- Mobile Menu Button (Placeholder) -->
        <button class="md:hidden text-amber">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-ink text-sand py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
          <div class="md:col-span-2">
            <h2 class="font-display text-3xl font-bold mb-4">Arkara</h2>
            <p class="text-sand/70 max-w-md leading-relaxed">
              Membangun ketangguhan bangsa melalui pengetahuan yang bisa diakses dan dipraktekkan oleh siapa saja, di mana saja.
            </p>
          </div>
          <div>
            <h3 class="font-bold uppercase tracking-widest text-amber mb-6">Navigasi</h3>
            <ul class="space-y-4 text-sm font-semibold">
              <li><a href="/" class="hover:text-amber">Beranda</a></li>
              <li><a href="/blog" class="hover:text-amber">Artikel Blog</a></li>
              <li><a href="/panduan" class="hover:text-amber">Panduan Teknis</a></li>
            </ul>
          </div>
        </div>
        
        <div class="border-t border-sand/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-sand/50">
          <p>&copy; 2026 Arkara — Survive with Knowledge. Semua hak dilindungi.</p>
          <div class="flex gap-8">
            <p>Terhubung dengan <strong>Buku Pegangan Krisis</strong> via QR code.</p>
          </div>
        </div>
      </div>
    </footer>

    <style is:global>
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      main {
        flex: 1;
      }
    </style>
  </body>
</html>
