---
/**
 * BaseLayout.astro â€” Arkara Retro Survival Manual 2.0
 * Replaces: old Playfair/sand/forest modern layout
 * Changes:
 *   - Nav: ink background, terminal cursor blink, mono font, sharp borders
 *   - Body: VFX layers (grain, grid, muted gradient)
 *   - Footer: dark surface, terminal-style labels
 *   - Typography: Barlow Condensed + Share Tech Mono
 */
import '../styles/global.css';
import { getFooterData } from '../lib/content';
import SearchAutosuggest from '../components/SearchAutosuggest.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonicalHref?: string;
  siteName?: string;
  type?: 'website' | 'article';
  robots?: string;
}

const {
  title,
  description = 'Platform pengetahuan survival Indonesia. Pelajari teknik survival praktis untuk menghadapi krisis.',
  image,
  imageAlt,
  canonicalHref,
  siteName = 'Arkara',
  type = 'website',
  robots = 'index, follow'
} = Astro.props;
const siteTitle = title ? `${title} â€” ${siteName}` : `${siteName} â€” Survive with Knowledge`;
const siteUrl = 'https://arkaraweb.com';
const canonicalUrl = new URL(canonicalHref || Astro.url.pathname, siteUrl);
const currentPath = Astro.url.pathname;
const footerData = await getFooterData();

const navLinks = [
  { label: 'BLOG',    href: '/blog' },
  { label: 'PANDUAN', href: '/panduan' },
];

const footerTagline = footerData?.tagline?.trim()
  || 'Membangun ketangguhan bangsa melalui pengetahuan yang bisa diakses dan dipraktekkan siapa saja.';
const footerCopyright = footerData?.copyright_text?.trim()
  || 'Â© 2026 ARKARA â€” SURVIVE WITH KNOWLEDGE';

function normalizePlatform(platform?: string) {
  return platform === 'twitter' ? 'x' : platform;
}

function getSocialCode(platform?: string) {
  switch (normalizePlatform(platform)) {
    case 'facebook':
      return 'FB';
    case 'youtube':
      return 'YT';
    case 'instagram':
      return 'IG';
    case 'x':
      return 'X';
    case 'reddit':
      return 'RD';
    case 'tiktok':
      return 'TT';
    default:
      return null;
  }
}

function getSocialLabel(platform?: string) {
  switch (normalizePlatform(platform)) {
    case 'facebook':
      return 'Facebook';
    case 'youtube':
      return 'YouTube';
    case 'instagram':
      return 'Instagram';
    case 'x':
      return 'X';
    case 'reddit':
      return 'Reddit';
    case 'tiktok':
      return 'TikTok';
    default:
      return 'Social';
  }
}

function isValidHttpUrl(url?: string) {
  if (!url) return false;

  try {
    const parsed = new URL(url);
    return parsed.protocol === 'http:' || parsed.protocol === 'https:';
  } catch {
    return false;
  }
}

const footerSocialLinks = (footerData?.social_links ?? [])
  .map((link) => ({
    platform: normalizePlatform(link?.platform),
    url: typeof link?.url === 'string' ? link.url.trim() : '',
  }))
  .filter((link) => getSocialCode(link.platform) && isValidHttpUrl(link.url));

if (Astro.response.status < 300) {
  const htmlCacheControl = 'public, max-age=0, s-maxage=600, stale-while-revalidate=86400';
  Astro.response.headers.set('Cache-Control', htmlCacheControl);
  Astro.response.headers.set('CDN-Cache-Control', htmlCacheControl);
}
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="title"       content={siteTitle} />
    <meta name="description" content={description} />
    <meta name="robots"      content={robots} />
    <link rel="canonical"    href={canonicalUrl.href} />

    <meta property="og:type"        content={type} />
    <meta property="og:url"         content={canonicalUrl.href} />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:title"       content={siteTitle} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={new URL(image, siteUrl).href} />}
    {image && <meta property="og:image:secure_url" content={new URL(image, siteUrl).href} />}
    {imageAlt && <meta property="og:image:alt" content={imageAlt} />}

    <meta property="twitter:card"        content="summary_large_image" />
    <meta property="twitter:url"         content={canonicalUrl.href} />
    <meta property="twitter:title"       content={siteTitle} />
    <meta property="twitter:description" content={description} />
    {image && <meta property="twitter:image" content={new URL(image, siteUrl).href} />}
    {imageAlt && <meta property="twitter:image:alt" content={imageAlt} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Share+Tech+Mono&family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Share+Tech+Mono&family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />
    </noscript>
  </head>

  <body>
    <!-- VFX: Grain + Grid + Gradient (behind everything) -->
    <div class="vfx-grain"  aria-hidden="true"></div>
    <div class="vfx-grid"   aria-hidden="true"></div>
    <div class="vfx-bg"     aria-hidden="true"></div>

    <!-- â”€â”€ NAVIGATION â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <nav id="main-nav" style="
      position: sticky; top: 0; z-index: 100;
      background: var(--ink);
      border-bottom: 3px solid var(--green-terminal);
      padding: 0 2rem;
      display: flex; align-items: center; justify-content: space-between;
      height: 52px;
    ">
      <!-- Brand -->
      <a href="/" style="
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.78rem;
        color: var(--green-terminal);
        letter-spacing: 0.15em;
        text-decoration: none;
        display: flex; align-items: center; gap: 0.75rem;
      ">
        <span class="nav-cursor" aria-hidden="true"></span>
        ARKARA_OS â€” SURVIVAL MANUAL
      </a>

      <!-- Desktop links -->
      <ul style="display: flex; gap: 0; list-style: none; margin: 0; padding: 0;" class="nav-links-desktop">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              style="
                font-family: 'Share Tech Mono', monospace;
                font-size: 0.65rem;
                letter-spacing: 0.12em;
                color: var(--cream-dark);
                text-decoration: none;
                padding: 0.5rem 1.1rem;
                border-left: 1px solid rgba(143,175,143,0.2);
                display: block;
                text-transform: uppercase;
                transition: background 0.15s, color 0.15s;
              "
              onmouseover="this.style.background='var(--green-dark)';this.style.color='var(--green-terminal)'"
              onmouseout="this.style.background='';this.style.color='var(--cream-dark)'"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <SearchAutosuggest variant="desktop" placeholder="Cari..." />

      <!-- Mobile hamburger -->
      <button id="nav-mobile-btn" class="nav-mobile-btn" aria-label="Menu" style="display: none;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--cream)" stroke-width="2.5">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile menu dropdown -->
    <div id="nav-mobile-menu" style="
      display: none;
      position: fixed; top: 52px; left: 0; right: 0;
      background: var(--ink);
      border-bottom: 3px solid var(--green-terminal);
      z-index: 99;
      padding: 0;
    ">
      {navLinks.map(link => (
        <a href={link.href} style="
          display: block;
          font-family: 'Share Tech Mono', monospace;
          font-size: 0.72rem;
          letter-spacing: 0.15em;
          color: var(--cream-dark);
          text-decoration: none;
          padding: 1rem 2rem;
          border-bottom: 1px solid rgba(143,175,143,0.1);
          text-transform: uppercase;
        ">{link.label}</a>
      ))}
    </div>

    <nav class="mobile-bottom-nav" aria-label="Navigasi bawah">
      <a href="/" class={currentPath === '/' ? 'active' : ''} aria-label="Beranda">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 10.5 12 4l8 6.5V20a1 1 0 0 1-1 1h-5v-6h-4v6H5a1 1 0 0 1-1-1v-9.5Z"/></svg>
        <span>Beranda</span>
      </a>
      <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''} aria-label="Artikel">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 3h9l3 3v15H6V3Z"/><path d="M14 3v4h4M8.5 11h7M8.5 15h7"/></svg>
        <span>Artikel</span>
      </a>
      <a href="/#mobile-search" aria-label="Cari">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        <span>Cari</span>
      </a>
      <a href="/panduan" class={currentPath.startsWith('/panduan') ? 'active' : ''} aria-label="Panduan">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H6.5A2.5 2.5 0 0 0 4 21.5v-16Z"/><path d="M4 5.5A2.5 2.5 0 0 1 6.5 8H20"/></svg>
        <span>Panduan</span>
      </a>
      <a href="/login" class={currentPath.startsWith('/login') ? 'active' : ''} aria-label="Profil">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4.5 21a7.5 7.5 0 0 1 15 0"/></svg>
        <span>Profil</span>
      </a>
    </nav>

    <!-- â”€â”€ MAIN CONTENT â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <main>
      <slot />
    </main>

    <!-- â”€â”€ FOOTER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <footer style="
      background: var(--ink);
      border-top: 3px solid var(--green-terminal);
      padding: 3rem 2rem;
      position: relative;
      z-index: 2;
    ">
      <div style="max-width: 1200px; margin: 0 auto;">
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 3rem; margin-bottom: 2.5rem;" class="footer-grid">

          <!-- Brand column -->
          <div>
            <div style="
              font-family: 'Share Tech Mono', monospace;
              font-size: 0.6rem;
              letter-spacing: 0.25em;
              color: var(--green-terminal);
              text-transform: uppercase;
              margin-bottom: 0.75rem;
            ">ARKARA_OS v2.0</div>
            <p style="
              font-family: 'Special Elite', cursive;
              font-size: 1.5rem;
              color: var(--cream);
              margin-bottom: 0.75rem;
              line-height: 1.2;
            ">Survive with Knowledge</p>
            <p style="
              font-size: 0.8rem;
              color: var(--warm-grey);
              line-height: 1.65;
              max-width: 240px;
            ">
              {footerTagline}
            </p>
            {footerSocialLinks.length > 0 && (
              <div style="margin-top: 1.25rem;">
                <div style="
                  font-family: 'Share Tech Mono', monospace;
                  font-size: 0.55rem;
                  letter-spacing: 0.2em;
                  color: var(--green-terminal);
                  text-transform: uppercase;
                  margin-bottom: 0.75rem;
                ">JARINGAN</div>
                <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
                  {footerSocialLinks.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={getSocialLabel(link.platform)}
                      title={getSocialLabel(link.platform)}
                      style="
                        display:inline-flex;
                        align-items:center;
                        justify-content:center;
                        min-width:38px;
                        height:32px;
                        padding:0 0.6rem;
                        border:1px solid rgba(143,175,143,0.35);
                        color:var(--cream-dark);
                        text-decoration:none;
                        font-family:'Share Tech Mono', monospace;
                        font-size:0.65rem;
                        letter-spacing:0.12em;
                        text-transform:uppercase;
                        background:rgba(143,175,143,0.05);
                        transition:background 0.15s,color 0.15s,border-color 0.15s;
                      "
                      onmouseover="this.style.background='var(--green-dark)';this.style.color='var(--green-terminal)';this.style.borderColor='var(--green-terminal)'"
                      onmouseout="this.style.background='rgba(143,175,143,0.05)';this.style.color='var(--cream-dark)';this.style.borderColor='rgba(143,175,143,0.35)'"
                    >
                      {getSocialCode(link.platform)}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Nav column -->
          <div>
            <div style="
              font-family: 'Share Tech Mono', monospace;
              font-size: 0.58rem;
              letter-spacing: 0.2em;
              color: var(--green-terminal);
              text-transform: uppercase;
              margin-bottom: 1.25rem;
              display: flex; align-items: center; gap: 0.5rem;
            ">
              <span style="display:inline-block;width:8px;height:1px;background:var(--green-terminal)"></span>
              NAVIGASI
            </div>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
              <li><a href="/" style="font-family:'Share Tech Mono',monospace;font-size:0.7rem;letter-spacing:0.1em;color:var(--warm-grey);text-decoration:none;text-transform:uppercase;transition:color 0.15s;" onmouseover="this.style.color='var(--green-terminal)'" onmouseout="this.style.color='var(--warm-grey)'">Beranda</a></li>
              <li><a href="/blog" style="font-family:'Share Tech Mono',monospace;font-size:0.7rem;letter-spacing:0.1em;color:var(--warm-grey);text-decoration:none;text-transform:uppercase;" onmouseover="this.style.color='var(--green-terminal)'" onmouseout="this.style.color='var(--warm-grey)'">Artikel Blog</a></li>
              <li><a href="/panduan" style="font-family:'Share Tech Mono',monospace;font-size:0.7rem;letter-spacing:0.1em;color:var(--warm-grey);text-decoration:none;text-transform:uppercase;" onmouseover="this.style.color='var(--green-terminal)'" onmouseout="this.style.color='var(--warm-grey)'">Panduan Teknis</a></li>
            </ul>
          </div>

          <!-- Status column -->
          <div>
            <div style="
              font-family: 'Share Tech Mono', monospace;
              font-size: 0.58rem;
              letter-spacing: 0.2em;
              color: var(--green-terminal);
              text-transform: uppercase;
              margin-bottom: 1.25rem;
              display: flex; align-items: center; gap: 0.5rem;
            ">
              <span style="display:inline-block;width:8px;height:1px;background:var(--green-terminal)"></span>
              STATUS SISTEM
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <div style="font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--warm-grey);display:flex;align-items:center;gap:0.5rem;">
                <span style="width:6px;height:6px;background:var(--green-terminal);border-radius:50%;animation:pulse-dot 2s infinite;flex-shrink:0;"></span>
                DATABASE: ONLINE
              </div>
              <div style="font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--warm-grey);display:flex;align-items:center;gap:0.5rem;">
                <span style="width:6px;height:6px;background:var(--green-terminal);border-radius:50%;animation:pulse-dot 2s infinite 0.4s;flex-shrink:0;"></span>
                KONTEN: TERSEDIA
              </div>
              <div style="font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--warm-grey);display:flex;align-items:center;gap:0.5rem;">
                <span style="width:6px;height:6px;background:var(--yellow-manual);border-radius:50%;flex-shrink:0;"></span>
                QR PANDUAN: AKTIF
              </div>
            </div>
          </div>
        </div>

        <!-- Footer bottom bar -->
        <div style="
          border-top: 1px solid rgba(143,175,143,0.15);
          padding-top: 1.5rem;
          display: flex;
          justify-content: space-between;
          align-items: center;
          flex-wrap: wrap;
          gap: 1rem;
        ">
          <p style="font-family:'Share Tech Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;color:var(--warm-grey-dark);">
            {footerCopyright}
          </p>
          <p aria-hidden="true" style="display:none;font-family:'Share Tech Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;color:var(--warm-grey-dark);">
            Â© 2026 ARKARA â€” SURVIVE WITH KNOWLEDGE
          </p>
          <p style="font-family:'Share Tech Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;color:var(--warm-grey-dark);">
            BUILD: 2026.01 â€” RAILWAY DEPLOY
          </p>
        </div>
      </div>
    </footer>

    <style>
      /* Cursor blink */
      .nav-cursor {
        display: inline-block;
        width: 8px; height: 14px;
        background: var(--green-terminal);
        animation: blink 1.2s steps(1) infinite;
      }

      .mobile-bottom-nav {
        display: none;
      }

      /* Responsive nav */
      @media (max-width: 768px) {
        #main-nav,
        #nav-mobile-menu {
          display: none !important;
        }

        main {
          padding-bottom: calc(78px + env(safe-area-inset-bottom));
        }

        footer {
          display: none !important;
        }

        .mobile-bottom-nav {
          position: fixed;
          left: 0;
          right: 0;
          bottom: 0;
          z-index: 120;
          display: grid;
          grid-template-columns: repeat(5, 1fr);
          gap: 0.2rem;
          padding: 0.55rem 0.75rem calc(0.65rem + env(safe-area-inset-bottom));
          border-top: 1px solid rgba(255,255,255,0.12);
          background: rgba(7,11,12,0.94);
          backdrop-filter: blur(18px);
        }

        .mobile-bottom-nav a {
          display: grid;
          justify-items: center;
          gap: 0.25rem;
          color: #e2e8f0;
          font-size: 0.68rem;
          text-decoration: none;
          line-height: 1;
        }

        .mobile-bottom-nav a.active {
          color: #63d2b5;
        }

        .mobile-bottom-nav svg {
          width: 1.45rem;
          height: 1.45rem;
        }

        .mobile-bottom-nav span {
          font-family: 'Barlow', system-ui, sans-serif;
          font-weight: 500;
        }
      }
    </style>

    <script>
      const btn  = document.getElementById('nav-mobile-btn');
      const menu = document.getElementById('nav-mobile-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.style.display === 'block';
        if (menu) menu.style.display = open ? 'none' : 'block';
      });
    </script>

  </body>
</html>

