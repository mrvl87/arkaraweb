---
/**
 * TableOfContents.astro — Retro Survival Manual 2.0
 * Props: unchanged — headings?: any[]
 * Changes:
 *   - Removed: rounded-3xl, shadow, modern styling
 *   - Added: ink border, mono heading label, terminal link style
 */
interface Props {
  headings?: any[];
  class?: string;
}
const { headings = [], class: className = '' } = Astro.props;
---

{headings && headings.length > 0 && (
  <div style={`
    background: var(--paper);
    border: 3px solid var(--ink);
    box-shadow: 4px 4px 0 var(--ink);
    padding: 1.5rem;
    position: sticky;
    top: 72px;
    ${className}
  `}>
    <!-- Label -->
    <div style="
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      color: var(--warm-grey);
      text-transform: uppercase;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    ">
      <span style="display:inline-block;width:16px;height:1px;background:var(--green-terminal);"></span>
      DAFTAR ISI
    </div>

    <!-- Links -->
    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.1rem;">
      {headings.map((heading) => (
        <li style={heading.depth === 3 ? 'padding-left: 1rem; border-left: 2px solid var(--cream-dark);' : ''}>
          <a
            href={`#${heading.slug}`}
            style={`
              display: block;
              font-family: 'Share Tech Mono', monospace;
              font-size: ${heading.depth === 2 ? '0.65rem' : '0.6rem'};
              letter-spacing: 0.1em;
              text-transform: uppercase;
              color: var(--warm-grey);
              text-decoration: none;
              padding: 0.4rem 0;
              border-bottom: 1px dashed var(--cream-dark);
              transition: color 0.15s;
              ${heading.depth === 2 ? 'font-weight: 700;' : ''}
            `}
            onmouseover="this.style.color='var(--green-terminal)'"
            onmouseout="this.style.color='var(--warm-grey)'"
          >
            {heading.depth === 2 ? '▸ ' : '  '}{heading.text}
          </a>
        </li>
      ))}
    </ul>

    <!-- Share section -->
    <div style="
      margin-top: 1.25rem;
      padding-top: 1rem;
      border-top: 2px solid var(--cream-dark);
    ">
      <p style="
        font-family: 'Share Tech Mono', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.2em;
        color: var(--warm-grey-dark);
        text-transform: uppercase;
        margin-bottom: 0.75rem;
      ">BAGIKAN</p>
      <div style="display: flex; gap: 0.5rem;">
        <button style="
          width: 32px; height: 32px;
          background: var(--paper-dark);
          border: 2px solid var(--ink);
          display: flex; align-items: center; justify-content: center;
          cursor: pointer;
          transition: background 0.15s;
        "
        onmouseover="this.style.background='var(--ink)';this.querySelector('svg').style.stroke='var(--cream)'"
        onmouseout="this.style.background='var(--paper-dark)';this.querySelector('svg').style.stroke='var(--warm-grey)'"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--warm-grey)" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </button>
        <button style="
          width: 32px; height: 32px;
          background: var(--paper-dark);
          border: 2px solid var(--ink);
          display: flex; align-items: center; justify-content: center;
          cursor: pointer;
          transition: background 0.15s;
        "
        onmouseover="this.style.background='var(--ink)';this.querySelector('svg').style.stroke='var(--cream)'"
        onmouseout="this.style.background='var(--paper-dark)';this.querySelector('svg').style.stroke='var(--warm-grey)'"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--warm-grey)" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
        </button>
      </div>
    </div>
  </div>
)}
