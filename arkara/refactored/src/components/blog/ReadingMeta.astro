---
/**
 * ReadingMeta.astro — Retro Survival Manual 2.0
 * Props: unchanged
 * Changes: amber-50 pill badge → mono terminal tag, modern dividers → mono dots
 */
interface Props {
  category: string;
  date: string;
  readingTime: number;
  class?: string;
}
const { category, date, readingTime, class: className = '' } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('id-ID', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---
<div style={`font-family:'Share Tech Mono',monospace;font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;display:flex;align-items:center;flex-wrap:wrap;gap:0.6rem;color:var(--warm-grey); ${className}`}>
  <span style="color:var(--green-terminal);border:1px solid var(--green-terminal);padding:0.15rem 0.5rem;">{category}</span>
  <span style="color:var(--warm-grey-dark);">·</span>
  <time datetime={date} style="color:var(--warm-grey);">{formattedDate}</time>
  <span style="color:var(--warm-grey-dark);">·</span>
  <span style="color:var(--warm-grey);">{readingTime} MENIT BACA</span>
</div>
