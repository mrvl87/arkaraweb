---
/**
 * blog/index.astro — Retro Survival Manual 2.0
 * Data fetching: unchanged (getPublishedPosts)
 * Changes:
 *   - Hero: ink bg + muted gradient, mono label, no dot grid
 *   - Category filter: mono pill → flat ink-border tabs
 *   - Layout: warning band above content, section labels
 */
import { getPublishedPosts } from '../../lib/content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';

const selectedCategory = Astro.url.searchParams.get('category') || undefined;
const sortedPosts = await getPublishedPosts({ category: selectedCategory });

const categories = ['air', 'energi', 'pangan', 'medis', 'keamanan', 'komunitas'];
const categoryLabels: Record<string, string> = {
  air: 'Air', energi: 'Energi', pangan: 'Pangan',
  medis: 'Medis', keamanan: 'Keamanan', komunitas: 'Komunitas',
};
---

<BaseLayout title="Blog">

  <!-- ── HEADER ────────────────────────────────────────── -->
  <header style="
    background: var(--ink);
    border-bottom: 3px solid var(--green-terminal);
    padding: 3.5rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  ">
    <!-- Grid texture -->
    <div style="
      position:absolute;inset:0;
      background-image:
        linear-gradient(rgba(143,175,143,0.04) 1px,transparent 1px),
        linear-gradient(90deg,rgba(143,175,143,0.04) 1px,transparent 1px);
      background-size:40px 40px;
      pointer-events:none;
    " aria-hidden="true"></div>

    <div style="max-width:1200px;margin:0 auto;position:relative;z-index:1;">
      <!-- Label -->
      <div style="
        font-family:'Share Tech Mono',monospace;
        font-size:0.6rem;letter-spacing:0.25em;
        color:var(--green-terminal);text-transform:uppercase;
        display:flex;align-items:center;gap:0.75rem;
        margin-bottom:1rem;
      ">
        <span style="display:inline-block;width:20px;height:1px;background:var(--green-terminal);"></span>
        ARKARA — ARSIP PENGETAHUAN
      </div>

      <!-- Title -->
      <h1 style="
        font-family:'Barlow Condensed',sans-serif;
        font-size:clamp(3rem,8vw,6rem);
        font-weight:800;text-transform:uppercase;
        color:var(--cream);line-height:0.9;
        letter-spacing:-0.01em;
        margin-bottom:1.25rem;
      ">ARKARA<br><span style="font-family:'Special Elite',cursive;text-transform:none;font-size:0.65em;color:var(--green-terminal);">Jurnal</span></h1>

      <p style="
        font-size:0.85rem;color:var(--warm-grey);
        max-width:440px;line-height:1.65;
        margin-bottom:2rem;
        border-left:3px solid var(--green-terminal);
        padding-left:1rem;
      ">
        Kumpulan pengetahuan, strategi, dan catatan lapangan untuk membangun kemandirian di era ketidakpastian.
      </p>

      <!-- Category filters — flat tab style -->
      <div style="display:flex;gap:0;flex-wrap:wrap;">
        <a href="/blog" style={`
          font-family:'Share Tech Mono',monospace;
          font-size:0.62rem;letter-spacing:0.12em;
          text-transform:uppercase;padding:0.5rem 1rem;
          text-decoration:none;
          border:2px solid ${!selectedCategory ? 'var(--green-terminal)' : 'rgba(143,175,143,0.2)'};
          background:${!selectedCategory ? 'var(--green-terminal)' : 'transparent'};
          color:${!selectedCategory ? 'var(--ink)' : 'var(--warm-grey)'};
          transition:all 0.15s;
          margin-right:2px;margin-bottom:4px;
          font-weight:${!selectedCategory ? '700' : '400'};
        `}>SEMUA</a>

        {categories.map(cat => (
          <a href={`/blog?category=${cat}`} style={`
            font-family:'Share Tech Mono',monospace;
            font-size:0.62rem;letter-spacing:0.12em;
            text-transform:uppercase;padding:0.5rem 1rem;
            text-decoration:none;
            border:2px solid ${selectedCategory === cat ? 'var(--green-terminal)' : 'rgba(143,175,143,0.2)'};
            background:${selectedCategory === cat ? 'var(--green-terminal)' : 'transparent'};
            color:${selectedCategory === cat ? 'var(--ink)' : 'var(--warm-grey)'};
            transition:all 0.15s;
            margin-right:2px;margin-bottom:4px;
            font-weight:${selectedCategory === cat ? '700' : '400'};
          `}>{categoryLabels[cat]}</a>
        ))}
      </div>
    </div>
  </header>

  <!-- ── CONTENT ────────────────────────────────────────── -->
  <section style="
    max-width:1200px;margin:0 auto;
    padding:3rem 2rem 5rem;
    position:relative;z-index:2;
  ">
    {sortedPosts.length > 0 ? (
      <>
        {/* Featured */}
        {!selectedCategory && sortedPosts.length > 0 && (
          <FeaturedPost
            post={sortedPosts[0]}
            categoryLabel={categoryLabels[sortedPosts[0].category] || sortedPosts[0].category}
          />
        )}

        <!-- Section label -->
        <div style="
          font-family:'Share Tech Mono',monospace;
          font-size:0.6rem;letter-spacing:0.25em;
          color:var(--warm-grey);text-transform:uppercase;
          display:flex;align-items:center;gap:1rem;
          margin-bottom:2rem;
        ">
          {selectedCategory ? categoryLabels[selectedCategory] : 'ARTIKEL TERBARU'}
          <span style="flex:1;height:1px;background:var(--cream-dark);max-width:80px;"></span>
        </div>

        <!-- Grid -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5px;background:var(--ink);border:3px solid var(--ink);" class="blog-grid">
          {(selectedCategory ? sortedPosts : sortedPosts.slice(1)).map(post => (
            <div style="background:var(--cream);">
              <PostCard
                title={post.title}
                excerpt={post.description || ''}
                category={categoryLabels[post.category] || post.category}
                date={post.published_at || ''}
                slug={post.slug}
                content={post.content || ''}
                image={post.thumbnail_image || post.cover_image}
              />
            </div>
          ))}
        </div>
      </>
    ) : (
      <div style="
        background:var(--paper);
        border:3px solid var(--ink);
        box-shadow:6px 6px 0 var(--ink);
        padding:4rem 2rem;text-align:center;
      ">
        <div style="font-size:4rem;margin-bottom:1rem;filter:saturate(0);">📭</div>
        <h2 style="
          font-family:'Barlow Condensed',sans-serif;
          font-size:2rem;font-weight:800;
          text-transform:uppercase;
          color:var(--ink);margin-bottom:0.5rem;
        ">JURNAL BELUM TERSEDIA</h2>
        <p style="font-size:0.85rem;color:var(--warm-grey);margin-bottom:1.5rem;">
          Belum ada artikel untuk kategori <strong>{selectedCategory}</strong> saat ini.
        </p>
        <a href="/blog" style="
          font-family:'Share Tech Mono',monospace;
          font-size:0.65rem;letter-spacing:0.15em;
          text-transform:uppercase;
          padding:0.7rem 1.4rem;
          background:var(--ink);color:var(--green-terminal);
          border:2px solid var(--green-terminal);
          text-decoration:none;
        ">TAMPILKAN SEMUA</a>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  @media (max-width: 900px) { .blog-grid { grid-template-columns: 1fr 1fr !important; } }
  @media (max-width: 640px) { .blog-grid { grid-template-columns: 1fr !important; } }
</style>
